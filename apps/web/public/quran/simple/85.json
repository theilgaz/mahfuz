{"verses":[{"v":1,"t":"وَالسَّمَاءِ ذَاتِ الْبُرُوجِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":2,"t":"وَالْيَوْمِ الْمَوْعُودِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":3,"t":"وَشَاهِدٍ وَمَشْهُودٍ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":4,"t":"قُتِلَ أَصْحَابُ الْأُخْدُودِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":5,"t":"النَّارِ ذَاتِ الْوَقُودِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":6,"t":"إِذْ هُمْ عَلَيْهَا قُعُودٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":7,"t":"وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِالْمُؤْمِنِينَ شُهُودٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":8,"t":"وَمَا نَقَمُوا مِنْهُمْ إِلَّا أَن يُؤْمِنُوا بِاللَّهِ الْعَزِيزِ الْحَمِيدِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":9,"t":"الَّذِي لَهُ مُلْكُ السَّمَاوَاتِ وَالْأَرْضِ وَاللَّهُ عَلَىٰ كُلِ͏ّ شَيْءٍ شَهِيدٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":10,"t":"إِنَّ الَّذِينَ فَتَنُوا الْمُؤْمِنِينَ وَالْمُؤْمِنَاتِ ثُمَّ لَمْ يَتُوبُوا فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ الْحَرِيقِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":11,"t":"إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ لَهُمْ جَنَّاتٌ تَجْرِي مِن تَحْتِهَا الْأَنْهَارُ ذَٰلِكَ الْفَوْزُ الْكَبِيرُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":12,"t":"إِنَّ بَطْشَ رَبِ͏ّكَ لَشَدِيدٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":13,"t":"إِنَّهُ هُوَ يُبْدِئُ وَيُعِيدُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":14,"t":"وَهُوَ الْغَفُورُ الْوَدُودُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":15,"t":"ذُو الْعَرْشِ الْمَجِيدُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":16,"t":"فَعَّالٌ لِ͏ّمَا يُرِيدُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":17,"t":"هَلْ أَتَاكَ حَدِيثُ الْجُنُودِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":18,"t":"فِرْعَوْنَ وَثَمُودَ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":19,"t":"بَلِ الَّذِينَ كَفَرُوا فِي تَكْذِيبٍ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":20,"t":"وَاللَّهُ مِن وَرَائِهِم مُّحِيطٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":21,"t":"بَلْ هُوَ قُرْآنٌ مَّجِيدٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":22,"t":"فِي لَوْحٍ مَّحْفُوظٍ","p":590,"j":30,"h":236,"rk":527,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}