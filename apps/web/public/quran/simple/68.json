{"verses":[{"v":1,"t":"ن وَالْقَلَمِ وَمَا يَسْطُرُونَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":2,"t":"مَا أَنتَ بِنِعْمَةِ رَبِ͏ّكَ بِمَجْنُونٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":3,"t":"وَإِنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":4,"t":"وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":5,"t":"فَسَتُبْصِرُ وَيُبْصِرُونَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":6,"t":"بِأَييِ͏ّكُمُ الْمَفْتُونُ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":7,"t":"إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِ وَهُوَ أَعْلَمُ بِالْمُهْتَدِينَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":8,"t":"فَلَا تُطِعِ الْمُكَذِ͏ّبِينَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":9,"t":"وَدُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":10,"t":"وَلَا تُطِعْ كُلَّ حَلَّافٍ مَّهِينٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":11,"t":"هَمَّازٍ مَّشَّاءٍ بِنَمِيمٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":12,"t":"مَّنَّاعٍ لِ͏ّلْخَيْرِ مُعْتَدٍ أَثِيمٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":13,"t":"عُتُلٍّ بَعْدَ ذَٰلِكَ زَنِيمٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":14,"t":"أَن كَانَ ذَا مَالٍ وَبَنِينَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":15,"t":"إِذَا تُتْلَىٰ عَلَيْهِ آيَاتُنَا قَالَ أَسَاطِيرُ الْأَوَّلِينَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":16,"t":"سَنَسِمُهُ عَلَى الْخُرْطُومِ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":17,"t":"إِنَّا بَلَوْنَاهُمْ كَمَا بَلَوْنَا أَصْحَابَ الْجَنَّةِ إِذْ أَقْسَمُوا لَيَصْرِمُنَّهَا مُصْبِحِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":18,"t":"وَلَا يَسْتَثْنُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":19,"t":"فَطَافَ عَلَيْهَا طَائِفٌ مِ͏ّن رَّبِ͏ّكَ وَهُمْ نَائِمُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":20,"t":"فَأَصْبَحَتْ كَالصَّرِيمِ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":21,"t":"فَتَنَادَوْا مُصْبِحِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":22,"t":"أَنِ اغْدُوا عَلَىٰ حَرْثِكُمْ إِن كُنتُمْ صَارِمِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":23,"t":"فَانطَلَقُوا وَهُمْ يَتَخَافَتُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":24,"t":"أَن لَّا يَدْخُلَنَّهَا الْيَوْمَ عَلَيْكُم مِ͏ّسْكِينٌ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":25,"t":"وَغَدَوْا عَلَىٰ حَرْدٍ قَادِرِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":26,"t":"فَلَمَّا رَأَوْهَا قَالُوا إِنَّا لَضَالُّونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":27,"t":"بَلْ نَحْنُ مَحْرُومُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":28,"t":"قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِ͏ّحُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":29,"t":"قَالُوا سُبْحَانَ رَبِ͏ّنَا إِنَّا كُنَّا ظَالِمِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":30,"t":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَلَاوَمُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":31,"t":"قَالُوا يَا وَيْلَنَا إِنَّا كُنَّا طَاغِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":32,"t":"عَسَىٰ رَبُّنَا أَن يُبْدِلَنَا خَيْرًا مِ͏ّنْهَا إِنَّا إِلَىٰ رَبِ͏ّنَا رَاغِبُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":33,"t":"كَذَٰلِكَ الْعَذَابُ وَلَعَذَابُ الْآخِرَةِ أَكْبَرُ لَوْ كَانُوا يَعْلَمُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":34,"t":"إِنَّ لِلْمُتَّقِينَ عِندَ رَبِ͏ّهِمْ جَنَّاتِ النَّعِيمِ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":35,"t":"أَفَنَجْعَلُ الْمُسْلِمِينَ كَالْمُجْرِمِينَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":36,"t":"مَا لَكُمْ كَيْفَ تَحْكُمُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":37,"t":"أَمْ لَكُمْ كِتَابٌ فِيهِ تَدْرُسُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":38,"t":"إِنَّ لَكُمْ فِيهِ لَمَا تَخَيَّرُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":39,"t":"أَمْ لَكُمْ أَيْمَانٌ عَلَيْنَا بَالِغَةٌ إِلَىٰ يَوْمِ الْقِيَامَةِ إِنَّ لَكُمْ لَمَا تَحْكُمُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":40,"t":"سَلْهُمْ أَيُّهُم بِذَٰلِكَ زَعِيمٌ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":41,"t":"أَمْ لَهُمْ شُرَكَاءُ فَلْيَأْتُوا بِشُرَكَائِهِمْ إِن كَانُوا صَادِقِينَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":42,"t":"يَوْمَ يُكْشَفُ عَن سَاقٍ وَيُدْعَوْنَ إِلَى السُّجُودِ فَلَا يَسْتَطِيعُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":43,"t":"خَاشِعَةً أَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ وَقَدْ كَانُوا يُدْعَوْنَ إِلَى السُّجُودِ وَهُمْ سَالِمُونَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":44,"t":"فَذَرْنِي وَمَن يُكَذِ͏ّبُ بِهَٰذَا الْحَدِيثِ سَنَسْتَدْرِجُهُم مِ͏ّنْ حَيْثُ لَا يَعْلَمُونَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":45,"t":"وَأُمْلِي لَهُمْ إِنَّ كَيْدِي مَتِينٌ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":46,"t":"أَمْ تَسْأَلُهُمْ أَجْرًا فَهُم مِ͏ّن مَّغْرَمٍ مُّثْقَلُونَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":47,"t":"أَمْ عِندَهُمُ الْغَيْبُ فَهُمْ يَكْتُبُونَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":48,"t":"فَاصْبِرْ لِحُكْمِ رَبِ͏ّكَ وَلَا تَكُن كَصَاحِبِ الْحُوتِ إِذْ نَادَىٰ وَهُوَ مَكْظُومٌ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":49,"t":"لَّوْلَا أَن تَدَارَكَهُ نِعْمَةٌ مِ͏ّن رَّبِ͏ّهِ لَنُبِذَ بِالْعَرَاءِ وَهُوَ مَذْمُومٌ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":50,"t":"فَاجْتَبَاهُ رَبُّهُ فَجَعَلَهُ مِنَ الصَّالِحِينَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":51,"t":"وَإِن يَكَادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصَارِهِمْ لَمَّا سَمِعُوا الذِ͏ّكْرَ وَيَقُولُونَ إِنَّهُ لَمَجْنُونٌ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":52,"t":"وَمَا هُوَ إِلَّا ذِكْرٌ لِ͏ّلْعَالَمِينَ","p":566,"j":29,"h":226,"rk":499,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}