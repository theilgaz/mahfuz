{"verses":[{"v":1,"t":"وَالسَّمَاءِ وَالطَّارِقِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":2,"t":"وَمَا أَدْرَاكَ مَا الطَّارِقُ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":3,"t":"النَّجْمُ الثَّاقِبُ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":4,"t":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":5,"t":"فَلْيَنظُرِ الْإِنسَانُ مِمَّ خُلِقَ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":6,"t":"خُلِقَ مِن مَّاءٍ دَافِقٍ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":7,"t":"يَخْرُجُ مِن بَيْنِ الصُّلْبِ وَالتَّرَائِبِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":8,"t":"إِنَّهُ عَلَىٰ رَجْعِهِ لَقَادِرٌ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":9,"t":"يَوْمَ تُبْلَى السَّرَائِرُ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":10,"t":"فَمَا لَهُ مِن قُوَّةٍ وَلَا نَاصِرٍ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":11,"t":"وَالسَّمَاءِ ذَاتِ الرَّجْعِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":12,"t":"وَالْأَرْضِ ذَاتِ الصَّدْعِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":13,"t":"إِنَّهُ لَقَوْلٌ فَصْلٌ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":14,"t":"وَمَا هُوَ بِالْهَزْلِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":15,"t":"إِنَّهُمْ يَكِيدُونَ كَيْدًا","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":16,"t":"وَأَكِيدُ كَيْدًا","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":17,"t":"فَمَهِ͏ّلِ الْكَافِرِينَ أَمْهِلْهُمْ رُوَيْدًا","p":591,"j":30,"h":236,"rk":528,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}