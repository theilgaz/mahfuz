{"verses":[{"v":1,"t":"إِنَّا أَنزَلْنَاهُ فِي لَيْلَةِ الْقَدْرِ","p":598,"j":30,"h":239,"rk":539,"m":7},{"v":2,"t":"وَمَا أَدْرَاكَ مَا لَيْلَةُ الْقَدْرِ","p":598,"j":30,"h":239,"rk":539,"m":7},{"v":3,"t":"لَيْلَةُ الْقَدْرِ خَيْرٌ مِ͏ّنْ أَلْفِ شَهْرٍ","p":598,"j":30,"h":239,"rk":539,"m":7},{"v":4,"t":"تَنَزَّلُ الْمَلَائِكَةُ وَالرُّوحُ فِيهَا بِإِذْنِ رَبِ͏ّهِم مِ͏ّن كُلِ͏ّ أَمْرٍ","p":598,"j":30,"h":239,"rk":539,"m":7},{"v":5,"t":"سَلَامٌ هِيَ حَتَّىٰ مَطْلَعِ الْفَجْرِ","p":598,"j":30,"h":239,"rk":539,"m":7}],"bismillah":"بِ͏ّسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}