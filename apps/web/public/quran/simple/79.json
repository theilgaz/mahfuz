{"verses":[{"v":1,"t":"وَالنَّازِعَاتِ غَرْقًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":2,"t":"وَالنَّاشِطَاتِ نَشْطًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":3,"t":"وَالسَّابِحَاتِ سَبْحًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":4,"t":"فَالسَّابِقَاتِ سَبْقًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":5,"t":"فَالْمُدَبِ͏ّرَاتِ أَمْرًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":6,"t":"يَوْمَ تَرْجُفُ الرَّاجِفَةُ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":7,"t":"تَتْبَعُهَا الرَّادِفَةُ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":8,"t":"قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":9,"t":"أَبْصَارُهَا خَاشِعَةٌ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":10,"t":"يَقُولُونَ أَإِنَّا لَمَرْدُودُونَ فِي الْحَافِرَةِ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":11,"t":"أَإِذَا كُنَّا عِظَامًا نَّخِرَةً","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":12,"t":"قَالُوا تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":13,"t":"فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَةٌ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":14,"t":"فَإِذَا هُم بِالسَّاهِرَةِ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":15,"t":"هَلْ أَتَاكَ حَدِيثُ مُوسَىٰ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":16,"t":"إِذْ نَادَاهُ رَبُّهُ بِالْوَادِ الْمُقَدَّسِ طُوًى","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":17,"t":"اذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُ طَغَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":18,"t":"فَقُلْ هَل لَّكَ إِلَىٰ أَن تَزَكَّىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":19,"t":"وَأَهْدِيَكَ إِلَىٰ رَبِ͏ّكَ فَتَخْشَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":20,"t":"فَأَرَاهُ الْآيَةَ الْكُبْرَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":21,"t":"فَكَذَّبَ وَعَصَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":22,"t":"ثُمَّ أَدْبَرَ يَسْعَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":23,"t":"فَحَشَرَ فَنَادَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":24,"t":"فَقَالَ أَنَا رَبُّكُمُ الْأَعْلَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":25,"t":"فَأَخَذَهُ اللَّهُ نَكَالَ الْآخِرَةِ وَالْأُولَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":26,"t":"إِنَّ فِي ذَٰلِكَ لَعِبْرَةً لِ͏ّمَن يَخْشَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":27,"t":"أَأَنتُمْ أَشَدُّ خَلْقًا أَمِ السَّمَاءُ بَنَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":28,"t":"رَفَعَ سَمْكَهَا فَسَوَّاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":29,"t":"وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":30,"t":"وَالْأَرْضَ بَعْدَ ذَٰلِكَ دَحَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":31,"t":"أَخْرَجَ مِنْهَا مَاءَهَا وَمَرْعَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":32,"t":"وَالْجِبَالَ أَرْسَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":33,"t":"مَتَاعًا لَّكُمْ وَلِأَنْعَامِكُمْ","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":34,"t":"فَإِذَا جَاءَتِ الطَّامَّةُ الْكُبْرَىٰ","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":35,"t":"يَوْمَ يَتَذَكَّرُ الْإِنسَانُ مَا سَعَىٰ","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":36,"t":"وَبُرِ͏ّزَتِ الْجَحِيمُ لِمَن يَرَىٰ","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":37,"t":"فَأَمَّا مَن طَغَىٰ","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":38,"t":"وَآثَرَ الْحَيَاةَ الدُّنْيَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":39,"t":"فَإِنَّ الْجَحِيمَ هِيَ الْمَأْوَىٰ","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":40,"t":"وَأَمَّا مَنْ خَافَ مَقَامَ رَبِ͏ّهِ وَنَهَى النَّفْسَ عَنِ الْهَوَىٰ","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":41,"t":"فَإِنَّ الْجَنَّةَ هِيَ الْمَأْوَىٰ","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":42,"t":"يَسْأَلُونَكَ عَنِ السَّاعَةِ أَيَّانَ مُرْسَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":43,"t":"فِيمَ أَنتَ مِن ذِكْرَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":44,"t":"إِلَىٰ رَبِ͏ّكَ مُنتَهَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":45,"t":"إِنَّمَا أَنتَ مُنذِرُ مَن يَخْشَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7},{"v":46,"t":"كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوا إِلَّا عَشِيَّةً أَوْ ضُحَاهَا","p":584,"j":30,"h":233,"rk":521,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}