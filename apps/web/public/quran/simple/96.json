{"verses":[{"v":1,"t":"اقْرَأْ بِاسْمِ رَبِ͏ّكَ الَّذِي خَلَقَ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":2,"t":"خَلَقَ الْإِنسَانَ مِنْ عَلَقٍ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":3,"t":"اقْرَأْ وَرَبُّكَ الْأَكْرَمُ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":4,"t":"الَّذِي عَلَّمَ بِالْقَلَمِ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":5,"t":"عَلَّمَ الْإِنسَانَ مَا لَمْ يَعْلَمْ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":6,"t":"كَلَّا إِنَّ الْإِنسَانَ لَيَطْغَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":7,"t":"أَن رَّآهُ اسْتَغْنَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":8,"t":"إِنَّ إِلَىٰ رَبِ͏ّكَ الرُّجْعَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":9,"t":"أَرَأَيْتَ الَّذِي يَنْهَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":10,"t":"عَبْدًا إِذَا صَلَّىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":11,"t":"أَرَأَيْتَ إِن كَانَ عَلَى الْهُدَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":12,"t":"أَوْ أَمَرَ بِالتَّقْوَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":13,"t":"أَرَأَيْتَ إِن كَذَّبَ وَتَوَلَّىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":14,"t":"أَلَمْ يَعْلَم بِأَنَّ اللَّهَ يَرَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":15,"t":"كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًا بِالنَّاصِيَةِ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":16,"t":"نَاصِيَةٍ كَاذِبَةٍ خَاطِئَةٍ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":17,"t":"فَلْيَدْعُ نَادِيَهُ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":18,"t":"سَنَدْعُ الزَّبَانِيَةَ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":19,"t":"كَلَّا لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِب","p":597,"j":30,"h":239,"rk":538,"m":7,"sj":2}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}