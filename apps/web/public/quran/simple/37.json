{"verses":[{"v":1,"t":"وَالصَّافَّاتِ صَفًّا","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":2,"t":"فَالزَّاجِرَاتِ زَجْرًا","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":3,"t":"فَالتَّالِيَاتِ ذِكْرًا","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":4,"t":"إِنَّ إِلَٰهَكُمْ لَوَاحِدٌ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":5,"t":"رَّبُّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ الْمَشَارِقِ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":6,"t":"إِنَّا زَيَّنَّا السَّمَاءَ الدُّنْيَا بِزِينَةٍ الْكَوَاكِبِ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":7,"t":"وَحِفْظًا مِ͏ّن كُلِ͏ّ شَيْطَانٍ مَّارِدٍ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":8,"t":"لَّا يَسَّمَّعُونَ إِلَى الْمَلَإِ الْأَعْلَىٰ وَيُقْذَفُونَ مِن كُلِ͏ّ جَانِبٍ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":9,"t":"دُحُورًا وَلَهُمْ عَذَابٌ وَاصِبٌ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":10,"t":"إِلَّا مَنْ خَطِفَ الْخَطْفَةَ فَأَتْبَعَهُ شِهَابٌ ثَاقِبٌ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":11,"t":"فَاسْتَفْتِهِمْ أَهُمْ أَشَدُّ خَلْقًا أَم مَّنْ خَلَقْنَا إِنَّا خَلَقْنَاهُم مِ͏ّن طِينٍ لَّازِبٍ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":12,"t":"بَلْ عَجِبْتَ وَيَسْخَرُونَ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":13,"t":"وَإِذَا ذُكِ͏ّرُوا لَا يَذْكُرُونَ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":14,"t":"وَإِذَا رَأَوْا آيَةً يَسْتَسْخِرُونَ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":15,"t":"وَقَالُوا إِنْ هَٰذَا إِلَّا سِحْرٌ مُّبِينٌ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":16,"t":"أَإِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَإِنَّا لَمَبْعُوثُونَ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":17,"t":"أَوَآبَاؤُنَا الْأَوَّلُونَ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":18,"t":"قُلْ نَعَمْ وَأَنتُمْ دَاخِرُونَ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":19,"t":"فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَةٌ فَإِذَا هُمْ يَنظُرُونَ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":20,"t":"وَقَالُوا يَا وَيْلَنَا هَٰذَا يَوْمُ الدِ͏ّينِ","p":446,"j":23,"h":178,"rk":386,"m":6},{"v":21