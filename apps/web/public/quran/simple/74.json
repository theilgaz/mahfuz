{"verses":[{"v":1,"t":"يَا أَيُّهَا الْمُدَّثِ͏ّرُ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":2,"t":"قُمْ فَأَنذِرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":3,"t":"وَرَبَّكَ فَكَبِ͏ّرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":4,"t":"وَثِيَابَكَ فَطَهِ͏ّرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":5,"t":"وَالرُّجْزَ فَاهْجُرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":6,"t":"وَلَا تَمْنُن تَسْتَكْثِرُ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":7,"t":"وَلِرَبِ͏ّكَ فَاصْبِرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":8,"t":"فَإِذَا نُقِرَ فِي النَّاقُورِ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":9,"t":"فَذَٰلِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":10,"t":"عَلَى الْكَافِرِينَ غَيْرُ يَسِيرٍ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":11,"t":"ذَرْنِي وَمَنْ خَلَقْتُ وَحِيدًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":12,"t":"وَجَعَلْتُ لَهُ مَالًا مَّمْدُودًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":13,"t":"وَبَنِينَ شُهُودًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":14,"t":"وَمَهَّدتُّ لَهُ تَمْهِيدًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":15,"t":"ثُمَّ يَطْمَعُ أَنْ أَزِيدَ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":16,"t":"كَلَّا إِنَّهُ كَانَ لِآيَاتِنَا عَنِيدًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":17,"t":"سَأُرْهِقُهُ صَعُودًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":18,"t":"إِنَّهُ فَكَّرَ وَقَدَّرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":19,"t":"فَقُتِلَ كَيْفَ قَدَّرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":20,"t":"ثُمَّ قُتِلَ كَيْفَ قَدَّرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":21,"t":"ثُمَّ نَظَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":22,"t":"ثُمَّ عَبَسَ وَبَسَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":23,"t":"ثُمَّ أَدْبَرَ وَاسْتَكْبَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":24,"t":"فَقَالَ إِنْ هَٰذَا إِلَّا سِحْرٌ يُؤْثَرُ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":25,"t":"إِنْ هَٰذَا إِلَّا قَوْلُ الْبَشَرِ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":26,"t":"سَأُصْلِيهِ سَقَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":27,"t":"وَمَا أَدْرَاكَ مَا سَقَرُ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":28,"t":"لَا تُبْقِي وَلَا تَذَرُ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":29,"t":"لَوَّاحَةٌ لِ͏ّلْبَشَرِ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":30,"t":"عَلَيْهَا تِسْعَةَ عَشَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":31,"t":"وَمَا جَعَلْنَا أَصْحَابَ النَّارِ إِلَّا مَلَائِكَةً وَمَا جَعَلْنَا عِدَّتَهُمْ إِلَّا فِتْنَةً لِ͏ّلَّذِينَ كَفَرُوا لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الْكِتَابَ وَيَزْدَادَ الَّذِينَ آمَنُوا إِيمَانًا وَلَا يَرْتَابَ الَّذِينَ أُوتُوا الْكِتَابَ وَالْمُؤْمِنُونَ وَلِيَقُولَ الَّذِينَ فِي قُلُوبِهِم مَّرَضٌ وَالْكَافِرُونَ مَاذَا أَرَادَ اللَّهُ بِهَٰذَا مَثَلًا كَذَٰلِكَ يُضِلُّ اللَّهُ مَن يَشَاءُ وَيَهْدِي مَن يَشَاءُ وَمَا يَعْلَمُ جُنُودَ رَبِ͏ّكَ إِلَّا هُوَ وَمَا هِيَ إِلَّا ذِكْرَىٰ لِلْبَشَرِ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":32,"t":"كَلَّا وَالْقَمَرِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":33,"t":"وَاللَّيْلِ إِذْ أَدْبَرَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":34,"t":"وَالصُّبْحِ إِذَا أَسْفَرَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":35,"t":"إِنَّهَا لَإِحْدَى الْكُبَرِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":36,"t":"نَذِيرًا لِ͏ّلْبَشَرِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":37,"t":"لِمَن شَاءَ مِنكُمْ أَن يَتَقَدَّمَ أَوْ يَتَأَخَّرَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":38,"t":"كُلُّ نَفْسٍ بِمَا كَسَبَتْ رَهِينَةٌ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":39,"t":"إِلَّا أَصْحَابَ الْيَمِينِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":40,"t":"فِي جَنَّاتٍ يَتَسَاءَلُونَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":41,"t":"عَنِ الْمُجْرِمِينَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":42,"t":"مَا سَلَكَكُمْ فِي سَقَرَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":43,"t":"قَالُوا لَمْ نَكُ مِنَ الْمُصَلِ͏ّينَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":44,"t":"وَلَمْ نَكُ نُطْعِمُ الْمِسْكِينَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":45,"t":"وَكُنَّا نَخُوضُ مَعَ الْخَائِضِينَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":46,"t":"وَكُنَّا نُكَذِ͏ّبُ بِيَوْمِ الدِ͏ّينِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":47,"t":"حَتَّىٰ أَتَانَا الْيَقِينُ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":48,"t":"فَمَا تَنفَعُهُمْ شَفَاعَةُ الشَّافِعِينَ","p":577,"j":29,"h":230,"rk":511,"m":7},{"v":49,"t":"فَمَا لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ","p":577,"j":29,"h":230,"rk":511,"m":7},{"v":50,"t":"كَأَنَّهُمْ حُمُرٌ مُّسْتَنفِرَةٌ","p":577,"j":29,"h":230,"rk":511,"m":7},{"v":51,"t":"فَرَّتْ مِن قَسْوَرَةٍ","p":577,"j":29,"h":230,"rk":511,"m":7},{"v":52,"t":"بَلْ يُرِيدُ كُلُّ امْرِئٍ مِ͏ّنْهُمْ أَن يُؤْتَىٰ صُحُفًا مُّنَشَّرَةً","p":577,"j":29,"h":230,"rk":511,"m":7},{"v":53,"t":"كَلَّا بَل لَّا يَخَافُونَ الْآخِرَةَ","p":577,"j":29,"h":230,"rk":511,"m":7},{"v":54,"t":"كَلَّا إِنَّهُ تَذْكِرَةٌ","p":577,"j":29,"h":230,"rk":511,"m":7},{"v":55,"t":"فَمَن شَاءَ ذَكَرَهُ","p":577,"j":29,"h":230,"rk":511,"m":7},{"v":56,"t":"وَمَا يَذْكُرُونَ إِلَّا أَن يَشَاءَ اللَّهُ هُوَ أَهْلُ التَّقْوَىٰ وَأَهْلُ الْمَغْفِرَةِ","p":577,"j":29,"h":230,"rk":511,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}