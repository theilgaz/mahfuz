{"verses":[{"v":1,"t":"أَرَأَيْتَ الَّذِي يُكَذِ͏ّبُ بِالدِ͏ّينِ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":2,"t":"فَذَٰلِكَ الَّذِي يَدُعُّ الْيَتِيمَ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":3,"t":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ الْمِسْكِينِ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":4,"t":"فَوَيْلٌ لِ͏ّلْمُصَلِ͏ّينَ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":5,"t":"الَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":6,"t":"الَّذِينَ هُمْ يُرَاءُونَ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":7,"t":"وَيَمْنَعُونَ الْمَاعُونَ","p":602,"j":30,"h":240,"rk":549,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}