{"verses":[{"v":1,"t":"أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","p":596,"j":30,"h":239,"rk":536,"m":7},{"v":2,"t":"وَوَضَعْنَا عَنكَ وِزْرَكَ","p":596,"j":30,"h":239,"rk":536,"m":7},{"v":3,"t":"الَّذِي أَنقَضَ ظَهْرَكَ","p":596,"j":30,"h":239,"rk":536,"m":7},{"v":4,"t":"وَرَفَعْنَا لَكَ ذِكْرَكَ","p":596,"j":30,"h":239,"rk":536,"m":7},{"v":5,"t":"فَإِنَّ مَعَ الْعُسْرِ يُسْرًا","p":596,"j":30,"h":239,"rk":536,"m":7},{"v":6,"t":"إِنَّ مَعَ الْعُسْرِ يُسْرًا","p":596,"j":30,"h":239,"rk":536,"m":7},{"v":7,"t":"فَإِذَا فَرَغْتَ فَانصَبْ","p":596,"j":30,"h":239,"rk":536,"m":7},{"v":8,"t":"وَإِلَىٰ رَبِ͏ّكَ فَارْغَب","p":596,"j":30,"h":239,"rk":536,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}