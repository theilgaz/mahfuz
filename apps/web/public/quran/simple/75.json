{"verses":[{"v":1,"t":"لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":2,"t":"وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":3,"t":"أَيَحْسَبُ الْإِنسَانُ أَلَّن نَّجْمَعَ عِظَامَهُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":4,"t":"بَلَىٰ قَادِرِينَ عَلَىٰ أَن نُّسَوِ͏ّيَ بَنَانَهُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":5,"t":"بَلْ يُرِيدُ الْإِنسَانُ لِيَفْجُرَ أَمَامَهُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":6,"t":"يَسْأَلُ أَيَّانَ يَوْمُ الْقِيَامَةِ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":7,"t":"فَإِذَا بَرِقَ الْبَصَرُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":8,"t":"وَخَسَفَ الْقَمَرُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":9,"t":"وَجُمِعَ الشَّمْسُ وَالْقَمَرُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":10,"t":"يَقُولُ الْإِنسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":11,"t":"كَلَّا لَا وَزَرَ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":12,"t":"إِلَىٰ رَبِ͏ّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":13,"t":"يُنَبَّأُ الْإِنسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":14,"t":"بَلِ الْإِنسَانُ عَلَىٰ نَفْسِهِ بَصِيرَةٌ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":15,"t":"وَلَوْ أَلْقَىٰ مَعَاذِيرَهُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":16,"t":"لَا تُحَرِ͏ّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":17,"t":"إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":18,"t":"فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":19,"t":"ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":20,"t":"كَلَّا بَلْ تُحِبُّونَ الْعَاجِلَةَ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":21,"t":"وَتَذَرُونَ الْآخِرَةَ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":22,"t":"وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":23,"t":"إِلَىٰ رَبِ͏ّهَا نَاظِرَةٌ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":24,"t":"وَوُجُوهٌ يَوْمَئِذٍ بَاسِرَةٌ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":25,"t":"تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":26,"t":"كَلَّا إِذَا بَلَغَتِ التَّرَاقِيَ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":27,"t":"وَقِيلَ مَنْ رَاقٍ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":28,"t":"وَظَنَّ أَنَّهُ الْفِرَاقُ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":29,"t":"وَالْتَفَّتِ السَّاقُ بِالسَّاقِ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":30,"t":"إِلَىٰ رَبِ͏ّكَ يَوْمَئِذٍ الْمَسَاقُ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":31,"t":"فَلَا صَدَّقَ وَلَا صَلَّىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":32,"t":"وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":33,"t":"ثُمَّ ذَهَبَ إِلَىٰ أَهْلِهِ يَتَمَطَّىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":34,"t":"أَوْلَىٰ لَكَ فَأَوْلَىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":35,"t":"ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":36,"t":"أَيَحْسَبُ الْإِنسَانُ أَن يُتْرَكَ سُدًى","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":37,"t":"أَلَمْ يَكُ نُطْفَةً مِ͏ّن مَّنِيٍّ يُمْنَىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":38,"t":"ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":39,"t":"فَجَعَلَ مِنْهُ الزَّوْجَيْنِ الذَّكَرَ وَالْأُنثَىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":40,"t":"أَلَيْسَ ذَٰلِكَ بِقَادِرٍ عَلَىٰ أَن يُحْيِيَ الْمَوْتَىٰ","p":578,"j":29,"h":231,"rk":513,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}