{"verses":[{"v":1,"t":"أَلْهَاكُمُ التَّكَاثُرُ","p":600,"j":30,"h":240,"rk":544,"m":7},{"v":2,"t":"حَتَّىٰ زُرْتُمُ الْمَقَابِرَ","p":600,"j":30,"h":240,"rk":544,"m":7},{"v":3,"t":"كَلَّا سَوْفَ تَعْلَمُونَ","p":600,"j":30,"h":240,"rk":544,"m":7},{"v":4,"t":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ","p":600,"j":30,"h":240,"rk":544,"m":7},{"v":5,"t":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ الْيَقِينِ","p":600,"j":30,"h":240,"rk":544,"m":7},{"v":6,"t":"لَتَرَوُنَّ الْجَحِيمَ","p":600,"j":30,"h":240,"rk":544,"m":7},{"v":7,"t":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ الْيَقِينِ","p":600,"j":30,"h":240,"rk":544,"m":7},{"v":8,"t":"ثُمَّ لَتُسْأَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ","p":600,"j":30,"h":240,"rk":544,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}