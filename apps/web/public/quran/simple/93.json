{"verses":[{"v":1,"t":"وَالضُّحَىٰ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":2,"t":"وَاللَّيْلِ إِذَا سَجَىٰ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":3,"t":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":4,"t":"وَلَلْآخِرَةُ خَيْرٌ لَّكَ مِنَ الْأُولَىٰ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":5,"t":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":6,"t":"أَلَمْ يَجِدْكَ يَتِيمًا فَآوَىٰ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":7,"t":"وَوَجَدَكَ ضَالًّا فَهَدَىٰ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":8,"t":"وَوَجَدَكَ عَائِلًا فَأَغْنَىٰ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":9,"t":"فَأَمَّا الْيَتِيمَ فَلَا تَقْهَرْ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":10,"t":"وَأَمَّا السَّائِلَ فَلَا تَنْهَرْ","p":596,"j":30,"h":238,"rk":535,"m":7},{"v":11,"t":"وَأَمَّا بِنِعْمَةِ رَبِ͏ّكَ فَحَدِ͏ّثْ","p":596,"j":30,"h":238,"rk":535,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}