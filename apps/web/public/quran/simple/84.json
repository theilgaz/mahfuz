{"verses":[{"v":1,"t":"إِذَا السَّمَاءُ انشَقَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":2,"t":"وَأَذِنَتْ لِرَبِ͏ّهَا وَحُقَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":3,"t":"وَإِذَا الْأَرْضُ مُدَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":4,"t":"وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":5,"t":"وَأَذِنَتْ لِرَبِ͏ّهَا وَحُقَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":6,"t":"يَا أَيُّهَا الْإِنسَانُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِ͏ّكَ كَدْحًا فَمُلَاقِيهِ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":7,"t":"فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":8,"t":"فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":9,"t":"وَيَنقَلِبُ إِلَىٰ أَهْلِهِ مَسْرُورًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":10,"t":"وَأَمَّا مَنْ أُوتِيَ كِتَابَهُ وَرَاءَ ظَهْرِهِ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":11,"t":"فَسَوْفَ يَدْعُو ثُبُورًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":12,"t":"وَيَصْلَىٰ سَعِيرًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":13,"t":"إِنَّهُ كَانَ فِي أَهْلِهِ مَسْرُورًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":14,"t":"إِنَّهُ ظَنَّ أَن لَّن يَحُورَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":15,"t":"بَلَىٰ إِنَّ رَبَّهُ كَانَ بِهِ بَصِيرًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":16,"t":"فَلَا أُقْسِمُ بِالشَّفَقِ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":17,"t":"وَاللَّيْلِ وَمَا وَسَقَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":18,"t":"وَالْقَمَرِ إِذَا اتَّسَقَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":19,"t":"لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":20,"t":"فَمَا لَهُمْ لَا يُؤْمِنُونَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":21,"t":"وَإِذَا قُرِئَ عَلَيْهِمُ الْقُرْآنُ لَا يَسْجُدُونَ","p":589,"j":30,"h":236,"rk":526,"m":7,"sj":1},{"v":22,"t":"بَلِ الَّذِينَ كَفَرُوا يُكَذِ͏ّبُونَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":23,"t":"وَاللَّهُ أَعْلَمُ بِمَا يُوعُونَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":24,"t":"فَبَشِ͏ّرْهُم بِعَذَابٍ أَلِيمٍ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":25,"t":"إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ","p":589,"j":30,"h":236,"rk":526,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}