{"verses":[{"v":1,"t":"عَمَّ يَتَسَاءَلُونَ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":2,"t":"عَنِ النَّبَإِ الْعَظِيمِ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":3,"t":"الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":4,"t":"كَلَّا سَيَعْلَمُونَ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":5,"t":"ثُمَّ كَلَّا سَيَعْلَمُونَ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":6,"t":"أَلَمْ نَجْعَلِ الْأَرْضَ مِهَادًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":7,"t":"وَالْجِبَالَ أَوْتَادًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":8,"t":"وَخَلَقْنَاكُمْ أَزْوَاجًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":9,"t":"وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":10,"t":"وَجَعَلْنَا اللَّيْلَ لِبَاسًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":11,"t":"وَجَعَلْنَا النَّهَارَ مَعَاشًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":12,"t":"وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":13,"t":"وَجَعَلْنَا سِرَاجًا وَهَّاجًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":14,"t":"وَأَنزَلْنَا مِنَ الْمُعْصِرَاتِ مَاءً ثَجَّاجًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":15,"t":"لِ͏ّنُخْرِجَ بِهِ حَبًّا وَنَبَاتًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":16,"t":"وَجَنَّاتٍ أَلْفَافًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":17,"t":"إِنَّ يَوْمَ الْفَصْلِ كَانَ مِيقَاتًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":18,"t":"يَوْمَ يُنفَخُ فِي الصُّورِ فَتَأْتُونَ أَفْوَاجًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":19,"t":"وَفُتِحَتِ السَّمَاءُ فَكَانَتْ أَبْوَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":20,"t":"وَسُيِ͏ّرَتِ الْجِبَالُ فَكَانَتْ سَرَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":21,"t":"إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":22,"t":"لِ͏ّلطَّاغِينَ مَآبًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":23,"t":"لَّابِثِينَ فِيهَا أَحْقَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":24,"t":"لَّا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":25,"t":"إِلَّا حَمِيمًا وَغَسَّاقًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":26,"t":"جَزَاءً وِفَاقًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":27,"t":"إِنَّهُمْ كَانُوا لَا يَرْجُونَ حِسَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":28,"t":"وَكَذَّبُوا بِآيَاتِنَا كِذَّابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":29,"t":"وَكُلَّ شَيْءٍ أَحْصَيْنَاهُ كِتَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":30,"t":"فَذُوقُوا فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":31,"t":"إِنَّ لِلْمُتَّقِينَ مَفَازًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":32,"t":"حَدَائِقَ وَأَعْنَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":33,"t":"وَكَوَاعِبَ أَتْرَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":34,"t":"وَكَأْسًا دِهَاقًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":35,"t":"لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":36,"t":"جَزَاءً مِ͏ّن رَّبِ͏ّكَ عَطَاءً حِسَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":37,"t":"رَّبِ͏ّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا الرَّحْمَٰنِ لَا يَمْلِكُونَ مِنْهُ خِطَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":38,"t":"يَوْمَ يَقُومُ الرُّوحُ وَالْمَلَائِكَةُ صَفًّا لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ الرَّحْمَٰنُ وَقَالَ صَوَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":39,"t":"ذَٰلِكَ الْيَوْمُ الْحَقُّ فَمَن شَاءَ اتَّخَذَ إِلَىٰ رَبِ͏ّهِ مَآبًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":40,"t":"إِنَّا أَنذَرْنَاكُمْ عَذَابًا قَرِيبًا يَوْمَ يَنظُرُ الْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ الْكَافِرُ يَا لَيْتَنِي كُنتُ تُرَابًا","p":583,"j":30,"h":233,"rk":519,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}