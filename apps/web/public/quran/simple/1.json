{"verses":[{"v":1,"t":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":2,"t":"الْحَمْدُ لِلَّهِ رَبِ͏ّ الْعَالَمِينَ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":3,"t":"الرَّحْمَٰنِ الرَّحِيمِ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":4,"t":"مَالِكِ يَوْمِ الدِ͏ّينِ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":5,"t":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":6,"t":"اهْدِنَا الصِ͏ّرَاطَ الْمُسْتَقِيمَ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":7,"t":"صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِ͏ّينَ","p":1,"j":1,"h":1,"rk":1,"m":1}]}