{"verses":[{"v":1,"t":"وَيْلٌ لِ͏ّكُلِ͏ّ هُمَزَةٍ لُّمَزَةٍ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":2,"t":"الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":3,"t":"يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":4,"t":"كَلَّا لَيُنبَذَنَّ فِي الْحُطَمَةِ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":5,"t":"وَمَا أَدْرَاكَ مَا الْحُطَمَةُ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":6,"t":"نَارُ اللَّهِ الْمُوقَدَةُ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":7,"t":"الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":8,"t":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":9,"t":"فِي عَمَدٍ مُّمَدَّدَةٍ","p":601,"j":30,"h":240,"rk":546,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}