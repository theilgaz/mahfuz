{"verses":[{"v":1,"t":"الْقَارِعَةُ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":2,"t":"مَا الْقَارِعَةُ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":3,"t":"وَمَا أَدْرَاكَ مَا الْقَارِعَةُ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":4,"t":"يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":5,"t":"وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنفُوشِ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":6,"t":"فَأَمَّا مَن ثَقُلَتْ مَوَازِينُهُ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":7,"t":"فَهُوَ فِي عِيشَةٍ رَّاضِيَةٍ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":8,"t":"وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":9,"t":"فَأُمُّهُ هَاوِيَةٌ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":10,"t":"وَمَا أَدْرَاكَ مَا هِيَهْ","p":600,"j":30,"h":240,"rk":543,"m":7},{"v":11,"t":"نَارٌ حَامِيَةٌ","p":600,"j":30,"h":240,"rk":543,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}