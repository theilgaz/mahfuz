{"verses":[{"v":1,"t":"لِإِيلَافِ قُرَيْشٍ","p":602,"j":30,"h":240,"rk":548,"m":7},{"v":2,"t":"إِيلَافِهِمْ رِحْلَةَ الشِ͏ّتَاءِ وَالصَّيْفِ","p":602,"j":30,"h":240,"rk":548,"m":7},{"v":3,"t":"فَلْيَعْبُدُوا رَبَّ هَٰذَا الْبَيْتِ","p":602,"j":30,"h":240,"rk":548,"m":7},{"v":4,"t":"الَّذِي أَطْعَمَهُم مِ͏ّن جُوعٍ وَآمَنَهُم مِ͏ّنْ خَوْفٍ","p":602,"j":30,"h":240,"rk":548,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}