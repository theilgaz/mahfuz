{"verses":[{"v":1,"t":"وَالْفَجْرِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":2,"t":"وَلَيَالٍ عَشْرٍ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":3,"t":"وَالشَّفْعِ وَالْوَتْرِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":4,"t":"وَاللَّيْلِ إِذَا يَسْرِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":5,"t":"هَلْ فِي ذَٰلِكَ قَسَمٌ لِ͏ّذِي حِجْرٍ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":6,"t":"أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":7,"t":"إِرَمَ ذَاتِ الْعِمَادِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":8,"t":"الَّتِي لَمْ يُخْلَقْ مِثْلُهَا فِي الْبِلَادِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":9,"t":"وَثَمُودَ الَّذِينَ جَابُوا الصَّخْرَ بِالْوَادِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":10,"t":"وَفِرْعَوْنَ ذِي الْأَوْتَادِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":11,"t":"الَّذِينَ طَغَوْا فِي الْبِلَادِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":12,"t":"فَأَكْثَرُوا فِيهَا الْفَسَادَ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":13,"t":"فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":14,"t":"إِنَّ رَبَّكَ لَبِالْمِرْصَادِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":15,"t":"فَأَمَّا الْإِنسَانُ إِذَا مَا ابْتَلَاهُ رَبُّهُ فَأَكْرَمَهُ وَنَعَّمَهُ فَيَقُولُ رَبِ͏ّي أَكْرَمَنِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":16,"t":"وَأَمَّا إِذَا مَا ابْتَلَاهُ فَقَدَرَ عَلَيْهِ رِزْقَهُ فَيَقُولُ رَبِ͏ّي أَهَانَنِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":17,"t":"كَلَّا بَل لَّا تُكْرِمُونَ الْيَتِيمَ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":18,"t":"وَلَا تَحَاضُّونَ عَلَىٰ طَعَامِ الْمِسْكِينِ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":19,"t":"وَتَأْكُلُونَ التُّرَاثَ أَكْلًا لَّمًّا","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":20,"t":"وَتُحِبُّونَ الْمَالَ حُبًّا جَمًّا","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":21,"t":"كَلَّا إِذَا دُكَّتِ الْأَرْضُ دَكًّا دَكًّا","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":22,"t":"وَجَاءَ رَبُّكَ وَالْمَلَكُ صَفًّا صَفًّا","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":23,"t":"وَجِيءَ يَوْمَئِذٍ بِجَهَنَّمَ يَوْمَئِذٍ يَتَذَكَّرُ الْإِنسَانُ وَأَنَّىٰ لَهُ الذِ͏ّكْرَىٰ","p":593,"j":30,"h":237,"rk":531,"m":7},{"v":24,"t":"يَقُولُ يَا لَيْتَنِي قَدَّمْتُ لِحَيَاتِي","p":594,"j":30,"h":237,"rk":531,"m":7},{"v":25,"t":"فَيَوْمَئِذٍ لَّا يُعَذِ͏ّبُ عَذَابَهُ أَحَدٌ","p":594,"j":30,"h":237,"rk":531,"m":7},{"v":26,"t":"وَلَا يُوثِقُ وَثَاقَهُ أَحَدٌ","p":594,"j":30,"h":237,"rk":531,"m":7},{"v":27,"t":"يَا أَيَّتُهَا النَّفْسُ الْمُطْمَئِنَّةُ","p":594,"j":30,"h":237,"rk":531,"m":7},{"v":28,"t":"ارْجِعِي إِلَىٰ رَبِ͏ّكِ رَاضِيَةً مَّرْضِيَّةً","p":594,"j":30,"h":237,"rk":531,"m":7},{"v":29,"t":"فَادْخُلِي فِي عِبَادِي","p":594,"j":30,"h":237,"rk":531,"m":7},{"v":30,"t":"وَادْخُلِي جَنَّتِي","p":594,"j":30,"h":237,"rk":531,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}