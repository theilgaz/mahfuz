{"verses":[{"v":1,"t":"وَالْعَادِيَاتِ ضَبْحًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":2,"t":"فَالْمُورِيَاتِ قَدْحًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":3,"t":"فَالْمُغِيرَاتِ صُبْحًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":4,"t":"فَأَثَرْنَ بِهِ نَقْعًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":5,"t":"فَوَسَطْنَ بِهِ جَمْعًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":6,"t":"إِنَّ الْإِنسَانَ لِرَبِ͏ّهِ لَكَنُودٌ","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":7,"t":"وَإِنَّهُ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":8,"t":"وَإِنَّهُ لِحُبِ͏ّ الْخَيْرِ لَشَدِيدٌ","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":9,"t":"أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِي الْقُبُورِ","p":599,"j":30,"h":240,"rk":542,"m":7},{"v":10,"t":"وَحُصِ͏ّلَ مَا فِي الصُّدُورِ","p":600,"j":30,"h":240,"rk":542,"m":7},{"v":11,"t":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌ","p":600,"j":30,"h":240,"rk":542,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}