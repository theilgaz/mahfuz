{"verses":[{"v":1,"t":"الْحَاقَّةُ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":2,"t":"مَا الْحَاقَّةُ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":3,"t":"وَمَا أَدْرَاكَ مَا الْحَاقَّةُ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":4,"t":"كَذَّبَتْ ثَمُودُ وَعَادٌ بِالْقَارِعَةِ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":5,"t":"فَأَمَّا ثَمُودُ فَأُهْلِكُوا بِالطَّاغِيَةِ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":6,"t":"وَأَمَّا عَادٌ فَأُهْلِكُوا بِرِيحٍ صَرْصَرٍ عَاتِيَةٍ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":7,"t":"سَخَّرَهَا عَلَيْهِمْ سَبْعَ لَيَالٍ وَثَمَانِيَةَ أَيَّامٍ حُسُومًا فَتَرَى الْقَوْمَ فِيهَا صَرْعَىٰ كَأَنَّهُمْ أَعْجَازُ نَخْلٍ خَاوِيَةٍ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":8,"t":"فَهَلْ تَرَىٰ لَهُم مِ͏ّن بَاقِيَةٍ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":9,"t":"وَجَاءَ فِرْعَوْنُ وَمَن قَبْلَهُ وَالْمُؤْتَفِكَاتُ بِالْخَاطِئَةِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":10,"t":"فَعَصَوْا رَسُولَ رَبِ͏ّهِمْ فَأَخَذَهُمْ أَخْذَةً رَّابِيَةً","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":11,"t":"إِنَّا لَمَّا طَغَى الْمَاءُ حَمَلْنَاكُمْ فِي الْجَارِيَةِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":12,"t":"لِنَجْعَلَهَا لَكُمْ تَذْكِرَةً وَتَعِيَهَا أُذُنٌ وَاعِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":13,"t":"فَإِذَا نُفِخَ فِي الصُّورِ نَفْخَةٌ وَاحِدَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":14,"t":"وَحُمِلَتِ الْأَرْضُ وَالْجِبَالُ فَدُكَّتَا دَكَّةً وَاحِدَةً","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":15,"t":"فَيَوْمَئِذٍ وَقَعَتِ الْوَاقِعَةُ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":16,"t":"وَانشَقَّتِ السَّمَاءُ فَهِيَ يَوْمَئِذٍ وَاهِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":17,"t":"وَالْمَلَكُ عَلَىٰ أَرْجَائِهَا وَيَحْمِلُ عَرْشَ رَبِ͏ّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمَانِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":18,"t":"يَوْمَئِذٍ تُعْرَضُونَ لَا تَخْفَىٰ مِنكُمْ خَافِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":19,"t":"فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ فَيَقُولُ هَاؤُمُ اقْرَءُوا كِتَابِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":20,"t":"إِنِ͏ّي ظَنَنتُ أَنِ͏ّي مُلَاقٍ حِسَابِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":21,"t":"فَهُوَ فِي عِيشَةٍ رَّاضِيَةٍ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":22,"t":"فِي جَنَّةٍ عَالِيَةٍ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":23,"t":"قُطُوفُهَا دَانِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":24,"t":"كُلُوا وَاشْرَبُوا هَنِيئًا بِمَا أَسْلَفْتُمْ فِي الْأَيَّامِ الْخَالِيَةِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":25,"t":"وَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِشِمَالِهِ فَيَقُولُ يَا لَيْتَنِي لَمْ أُوتَ كِتَابِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":26,"t":"وَلَمْ أَدْرِ مَا حِسَابِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":27,"t":"يَا لَيْتَهَا كَانَتِ الْقَاضِيَةَ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":28,"t":"مَا أَغْنَىٰ عَنِ͏ّي مَالِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":29,"t":"هَلَكَ عَنِ͏ّي سُلْطَانِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":30,"t":"خُذُوهُ فَغُلُّوهُ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":31,"t":"ثُمَّ الْجَحِيمَ صَلُّوهُ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":32,"t":"ثُمَّ فِي سِلْسِلَةٍ ذَرْعُهَا سَبْعُونَ ذِرَاعًا فَاسْلُكُوهُ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":33,"t":"إِنَّهُ كَانَ لَا يُؤْمِنُ بِاللَّهِ الْعَظِيمِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":34,"t":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ الْمِسْكِينِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":35,"t":"فَلَيْسَ لَهُ الْيَوْمَ هَاهُنَا حَمِيمٌ","p":568,"j":29,"h":227,"rk":500,"m":7},{"v":36,"t":"وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍ","p":568,"j":29,"h":227,"rk":500,"m":7},{"v":37,"t":"لَّا يَأْكُلُهُ إِلَّا الْخَاطِئُونَ","p":568,"j":29,"h":227,"rk":500,"m":7},{"v":38,"t":"فَلَا أُقْسِمُ بِمَا تُبْصِرُونَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":39,"t":"وَمَا لَا تُبْصِرُونَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":40,"t":"إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":41,"t":"وَمَا هُوَ بِقَوْلِ شَاعِرٍ قَلِيلًا مَّا تُؤْمِنُونَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":42,"t":"وَلَا بِقَوْلِ كَاهِنٍ قَلِيلًا مَّا تَذَكَّرُونَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":43,"t":"تَنزِيلٌ مِ͏ّن رَّبِ͏ّ الْعَالَمِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":44,"t":"وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ الْأَقَاوِيلِ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":45,"t":"لَأَخَذْنَا مِنْهُ بِالْيَمِينِ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":46,"t":"ثُمَّ لَقَطَعْنَا مِنْهُ الْوَتِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":47,"t":"فَمَا مِنكُم مِ͏ّنْ أَحَدٍ عَنْهُ حَاجِزِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":48,"t":"وَإِنَّهُ لَتَذْكِرَةٌ لِ͏ّلْمُتَّقِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":49,"t":"وَإِنَّا لَنَعْلَمُ أَنَّ مِنكُم مُّكَذِ͏ّبِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":50,"t":"وَإِنَّهُ لَحَسْرَةٌ عَلَى الْكَافِرِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":51,"t":"وَإِنَّهُ لَحَقُّ الْيَقِينِ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":52,"t":"فَسَبِ͏ّحْ بِاسْمِ رَبِ͏ّكَ الْعَظِيمِ","p":568,"j":29,"h":227,"rk":501,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}