{"verses":[{"v":1,"t":"وَيْلٌ لِ͏ّلْمُطَفِ͏ّفِينَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":2,"t":"الَّذِينَ إِذَا اكْتَالُوا عَلَى النَّاسِ يَسْتَوْفُونَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":3,"t":"وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":4,"t":"أَلَا يَظُنُّ أُولَٰئِكَ أَنَّهُم مَّبْعُوثُونَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":5,"t":"لِيَوْمٍ عَظِيمٍ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":6,"t":"يَوْمَ يَقُومُ النَّاسُ لِرَبِ͏ّ الْعَالَمِينَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":7,"t":"كَلَّا إِنَّ كِتَابَ الْفُجَّارِ لَفِي سِجِ͏ّينٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":8,"t":"وَمَا أَدْرَاكَ مَا سِجِ͏ّينٌ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":9,"t":"كِتَابٌ مَّرْقُومٌ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":10,"t":"وَيْلٌ يَوْمَئِذٍ لِ͏ّلْمُكَذِ͏ّبِينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":11,"t":"الَّذِينَ يُكَذِ͏ّبُونَ بِيَوْمِ الدِ͏ّينِ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":12,"t":"وَمَا يُكَذِ͏ّبُ بِهِ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":13,"t":"إِذَا تُتْلَىٰ عَلَيْهِ آيَاتُنَا قَالَ أَسَاطِيرُ الْأَوَّلِينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":14,"t":"كَلَّا بَلْ رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُوا يَكْسِبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":15,"t":"كَلَّا إِنَّهُمْ عَن رَّبِ͏ّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":16,"t":"ثُمَّ إِنَّهُمْ لَصَالُو الْجَحِيمِ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":17,"t":"ثُمَّ يُقَالُ هَٰذَا الَّذِي كُنتُم بِهِ تُكَذِ͏ّبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":18,"t":"كَلَّا إِنَّ كِتَابَ الْأَبْرَارِ لَفِي عِلِ͏ّيِ͏ّينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":19,"t":"وَمَا أَدْرَاكَ مَا عِلِ͏ّيُّونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":20,"t":"كِتَابٌ مَّرْقُومٌ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":21,"t":"يَشْهَدُهُ الْمُقَرَّبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":22,"t":"إِنَّ الْأَبْرَارَ لَفِي نَعِيمٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":23,"t":"عَلَى الْأَرَائِكِ يَنظُرُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":24,"t":"تَعْرِفُ فِي وُجُوهِهِمْ نَضْرَةَ النَّعِيمِ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":25,"t":"يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":26,"t":"خِتَامُهُ مِسْكٌ وَفِي ذَٰلِكَ فَلْيَتَنَافَسِ الْمُتَنَافِسُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":27,"t":"وَمِزَاجُهُ مِن تَسْنِيمٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":28,"t":"عَيْنًا يَشْرَبُ بِهَا الْمُقَرَّبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":29,"t":"إِنَّ الَّذِينَ أَجْرَمُوا كَانُوا مِنَ الَّذِينَ آمَنُوا يَضْحَكُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":30,"t":"وَإِذَا مَرُّوا بِهِمْ يَتَغَامَزُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":31,"t":"وَإِذَا انقَلَبُوا إِلَىٰ أَهْلِهِمُ انقَلَبُوا فَكِهِينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":32,"t":"وَإِذَا رَأَوْهُمْ قَالُوا إِنَّ هَٰؤُلَاءِ لَضَالُّونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":33,"t":"وَمَا أُرْسِلُوا عَلَيْهِمْ حَافِظِينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":34,"t":"فَالْيَوْمَ الَّذِينَ آمَنُوا مِنَ الْكُفَّارِ يَضْحَكُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":35,"t":"عَلَى الْأَرَائِكِ يَنظُرُونَ","p":589,"j":30,"h":235,"rk":525,"m":7},{"v":36,"t":"هَلْ ثُوِ͏ّبَ الْكُفَّارُ مَا كَانُوا يَفْعَلُونَ","p":589,"j":30,"h":235,"rk":525,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}