{"verses":[{"v":1,"t":"قُلْ يَا أَيُّهَا الْكَافِرُونَ","p":603,"j":30,"h":240,"rk":551,"m":7},{"v":2,"t":"لَا أَعْبُدُ مَا تَعْبُدُونَ","p":603,"j":30,"h":240,"rk":551,"m":7},{"v":3,"t":"وَلَا أَنتُمْ عَابِدُونَ مَا أَعْبُدُ","p":603,"j":30,"h":240,"rk":551,"m":7},{"v":4,"t":"وَلَا أَنَا عَابِدٌ مَّا عَبَدتُّمْ","p":603,"j":30,"h":240,"rk":551,"m":7},{"v":5,"t":"وَلَا أَنتُمْ عَابِدُونَ مَا أَعْبُدُ","p":603,"j":30,"h":240,"rk":551,"m":7},{"v":6,"t":"لَكُمْ دِينُكُمْ وَلِيَ دِينِ","p":603,"j":30,"h":240,"rk":551,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}