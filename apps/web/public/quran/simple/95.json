{"verses":[{"v":1,"t":"وَالتِ͏ّينِ وَالزَّيْتُونِ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":2,"t":"وَطُورِ سِينِينَ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":3,"t":"وَهَٰذَا الْبَلَدِ الْأَمِينِ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":4,"t":"لَقَدْ خَلَقْنَا الْإِنسَانَ فِي أَحْسَنِ تَقْوِيمٍ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":5,"t":"ثُمَّ رَدَدْنَاهُ أَسْفَلَ سَافِلِينَ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":6,"t":"إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":7,"t":"فَمَا يُكَذِ͏ّبُكَ بَعْدُ بِالدِ͏ّينِ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":8,"t":"أَلَيْسَ اللَّهُ بِأَحْكَمِ الْحَاكِمِينَ","p":597,"j":30,"h":239,"rk":537,"m":7}],"bismillah":"بِ͏ّسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}