{"verses":[{"v":1,"t":"تَبَّتْ يَدَا أَبِي لَهَبٍ وَتَبَّ","p":603,"j":30,"h":240,"rk":553,"m":7},{"v":2,"t":"مَا أَغْنَىٰ عَنْهُ مَالُهُ وَمَا كَسَبَ","p":603,"j":30,"h":240,"rk":553,"m":7},{"v":3,"t":"سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ","p":603,"j":30,"h":240,"rk":553,"m":7},{"v":4,"t":"وَامْرَأَتُهُ حَمَّالَةَ الْحَطَبِ","p":603,"j":30,"h":240,"rk":553,"m":7},{"v":5,"t":"فِي جِيدِهَا حَبْلٌ مِ͏ّن مَّسَدٍ","p":603,"j":30,"h":240,"rk":553,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}