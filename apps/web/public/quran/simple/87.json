{"verses":[{"v":1,"t":"سَبِ͏ّحِ اسْمَ رَبِ͏ّكَ الْأَعْلَى","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":2,"t":"الَّذِي خَلَقَ فَسَوَّىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":3,"t":"وَالَّذِي قَدَّرَ فَهَدَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":4,"t":"وَالَّذِي أَخْرَجَ الْمَرْعَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":5,"t":"فَجَعَلَهُ غُثَاءً أَحْوَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":6,"t":"سَنُقْرِئُكَ فَلَا تَنسَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":7,"t":"إِلَّا مَا شَاءَ اللَّهُ إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":8,"t":"وَنُيَسِ͏ّرُكَ لِلْيُسْرَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":9,"t":"فَذَكِ͏ّرْ إِن نَّفَعَتِ الذِ͏ّكْرَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":10,"t":"سَيَذَّكَّرُ مَن يَخْشَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":11,"t":"وَيَتَجَنَّبُهَا الْأَشْقَى","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":12,"t":"الَّذِي يَصْلَى النَّارَ الْكُبْرَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":13,"t":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":14,"t":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":15,"t":"وَذَكَرَ اسْمَ رَبِ͏ّهِ فَصَلَّىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":16,"t":"بَلْ تُؤْثِرُونَ الْحَيَاةَ الدُّنْيَا","p":592,"j":30,"h":237,"rk":529,"m":7},{"v":17,"t":"وَالْآخِرَةُ خَيْرٌ وَأَبْقَىٰ","p":592,"j":30,"h":237,"rk":529,"m":7},{"v":18,"t":"إِنَّ هَٰذَا لَفِي الصُّحُفِ الْأُولَىٰ","p":592,"j":30,"h":237,"rk":529,"m":7},{"v":19,"t":"صُحُفِ إِبْرَاهِيمَ وَمُوسَىٰ","p":592,"j":30,"h":237,"rk":529,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}