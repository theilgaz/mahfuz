{"verses":[{"v":1,"t":"لَا أُقْسِمُ بِهَٰذَا الْبَلَدِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":2,"t":"وَأَنتَ حِلٌّ بِهَٰذَا الْبَلَدِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":3,"t":"وَوَالِدٍ وَمَا وَلَدَ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":4,"t":"لَقَدْ خَلَقْنَا الْإِنسَانَ فِي كَبَدٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":5,"t":"أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":6,"t":"يَقُولُ أَهْلَكْتُ مَالًا لُّبَدًا","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":7,"t":"أَيَحْسَبُ أَن لَّمْ يَرَهُ أَحَدٌ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":8,"t":"أَلَمْ نَجْعَل لَّهُ عَيْنَيْنِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":9,"t":"وَلِسَانًا وَشَفَتَيْنِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":10,"t":"وَهَدَيْنَاهُ النَّجْدَيْنِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":11,"t":"فَلَا اقْتَحَمَ الْعَقَبَةَ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":12,"t":"وَمَا أَدْرَاكَ مَا الْعَقَبَةُ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":13,"t":"فَكُّ رَقَبَةٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":14,"t":"أَوْ إِطْعَامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":15,"t":"يَتِيمًا ذَا مَقْرَبَةٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":16,"t":"أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":17,"t":"ثُمَّ كَانَ مِنَ الَّذِينَ آمَنُوا وَتَوَاصَوْا بِالصَّبْرِ وَتَوَاصَوْا بِالْمَرْحَمَةِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":18,"t":"أُولَٰئِكَ أَصْحَابُ الْمَيْمَنَةِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":19,"t":"وَالَّذِينَ كَفَرُوا بِآيَاتِنَا هُمْ أَصْحَابُ الْمَشْأَمَةِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":20,"t":"عَلَيْهِمْ نَارٌ مُّؤْصَدَةٌ","p":594,"j":30,"h":238,"rk":532,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}