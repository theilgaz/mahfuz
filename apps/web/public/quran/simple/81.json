{"verses":[{"v":1,"t":"إِذَا الشَّمْسُ كُوِ͏ّرَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":2,"t":"وَإِذَا النُّجُومُ انكَدَرَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":3,"t":"وَإِذَا الْجِبَالُ سُيِ͏ّرَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":4,"t":"وَإِذَا الْعِشَارُ عُطِ͏ّلَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":5,"t":"وَإِذَا الْوُحُوشُ حُشِرَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":6,"t":"وَإِذَا الْبِحَارُ سُجِ͏ّرَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":7,"t":"وَإِذَا النُّفُوسُ زُوِ͏ّجَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":8,"t":"وَإِذَا الْمَوْءُودَةُ سُئِلَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":9,"t":"بِأَيِ͏ّ ذَنبٍ قُتِلَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":10,"t":"وَإِذَا الصُّحُفُ نُشِرَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":11,"t":"وَإِذَا السَّمَاءُ كُشِطَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":12,"t":"وَإِذَا الْجَحِيمُ سُعِ͏ّرَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":13,"t":"وَإِذَا الْجَنَّةُ أُزْلِفَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":14,"t":"عَلِمَتْ نَفْسٌ مَّا أَحْضَرَتْ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":15,"t":"فَلَا أُقْسِمُ بِالْخُنَّسِ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":16,"t":"الْجَوَارِ الْكُنَّسِ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":17,"t":"وَاللَّيْلِ إِذَا عَسْعَسَ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":18,"t":"وَالصُّبْحِ إِذَا تَنَفَّسَ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":19,"t":"إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":20,"t":"ذِي قُوَّةٍ عِندَ ذِي الْعَرْشِ مَكِينٍ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":21,"t":"مُّطَاعٍ ثَمَّ أَمِينٍ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":22,"t":"وَمَا صَاحِبُكُم بِمَجْنُونٍ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":23,"t":"وَلَقَدْ رَآهُ بِالْأُفُقِ الْمُبِينِ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":24,"t":"وَمَا هُوَ عَلَى الْغَيْبِ بِضَنِينٍ","p":586,"j":30,"h":234,"rk":523,"m":7},{"v":25,"t":"