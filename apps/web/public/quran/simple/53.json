{"verses":[{"v":1,"t":"وَالنَّجْمِ إِذَا هَوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":2,"t":"مَا ضَلَّ صَاحِبُكُمْ وَمَا غَوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":3,"t":"وَمَا يَنطِقُ عَنِ الْهَوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":4,"t":"إِنْ هُوَ إِلَّا وَحْيٌ يُوحَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":5,"t":"عَلَّمَهُ شَدِيدُ الْقُوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":6,"t":"ذُو مِرَّةٍ فَاسْتَوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":7,"t":"وَهُوَ بِالْأُفُقِ الْأَعْلَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":8,"t":"ثُمَّ دَنَا فَتَدَلَّىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":9,"t":"فَكَانَ قَابَ قَوْسَيْنِ أَوْ أَدْنَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":10,"t":"فَأَوْحَىٰ إِلَىٰ عَبْدِهِ مَا أَوْحَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":11,"t":"مَا كَذَبَ الْفُؤَادُ مَا رَأَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":12,"t":"أَفَتُمَارُونَهُ عَلَىٰ مَا يَرَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":13,"t":"وَلَقَدْ رَآهُ نَزْلَةً أُخْرَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":14,"t":"عِندَ سِدْرَةِ الْمُنتَهَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":15,"t":"عِندَهَا جَنَّةُ الْمَأْوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":16,"t":"إِذْ يَغْشَى السِ͏ّدْرَةَ مَا يَغْشَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":17,"t":"مَا زَاغَ الْبَصَرُ وَمَا طَغَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":18,"t":"لَقَدْ رَأَىٰ مِنْ آيَاتِ رَبِ͏ّهِ الْكُبْرَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":19,"t":"أَفَرَأَيْتُمُ اللَّاتَ وَالْعُزَّىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":20,"t":"وَمَنَاةَ الثَّالِثَةَ الْأُخْرَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":21,"t":"أَلَكُمُ الذَّكَرُ وَلَهُ الْأُنثَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":22,"t":"تِلْكَ إِذًا قِسْمَةٌ ضِيزَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":23,"t":"إِنْ هِيَ إِلَّا أَسْمَاءٌ سَمَّيْتُمُوهَا أَنتُمْ وَآبَاؤُكُم مَّا أَنزَلَ اللَّهُ بِهَا مِن سُلْطَانٍ إِن يَتَّبِعُونَ إِلَّا الظَّنَّ وَمَا تَهْوَى الْأَنفُسُ وَلَقَدْ جَاءَهُم مِ͏ّن رَّبِ͏ّهِمُ الْهُدَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":24,"t":"أَمْ لِلْإِنسَانِ مَا تَمَنَّىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":25,"t":"فَلِلَّهِ الْآخِرَةُ وَالْأُولَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":26,"t":"وَكَم مِ͏ّن مَّلَكٍ فِي السَّمَاوَاتِ لَا تُغْنِي شَفَاعَتُهُمْ شَيْئًا إِلَّا مِن بَعْدِ أَن يَأْذَنَ اللَّهُ لِمَن يَشَاءُ وَيَرْضَىٰ","p":526,"j":27,"h":211,"rk":461,"m":7},{"v":27,"t":"إِنَّ الَّذِينَ لَا يُؤْمِنُونَ بِالْآخِرَةِ لَيُسَمُّونَ الْمَلَائِكَةَ تَسْمِيَةَ الْأُنثَىٰ","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":28,"t":"وَمَا لَهُم بِهِ مِنْ عِلْمٍ إِن يَتَّبِعُونَ إِلَّا الظَّنَّ وَإِنَّ الظَّنَّ لَا يُغْنِي مِنَ الْحَقِ͏ّ شَيْئًا","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":29,"t":"فَأَعْرِضْ عَن مَّن تَوَلَّىٰ عَن ذِكْرِنَا وَلَمْ يُرِدْ إِلَّا الْحَيَاةَ الدُّنْيَا","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":30,"t":"ذَٰلِكَ مَبْلَغُهُم مِ͏ّنَ الْعِلْمِ إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِ وَهُوَ أَعْلَمُ بِمَنِ اهْتَدَىٰ","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":31,"t":"وَلِلَّهِ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ لِيَجْزِيَ الَّذِينَ أَسَاءُوا بِمَا عَمِلُوا وَيَجْزِيَ الَّذِينَ أَحْسَنُوا بِالْحُسْنَى","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":32,"t":"الَّذِينَ يَجْتَنِبُونَ كَبَائِرَ الْإِثْمِ وَالْفَوَاحِشَ إِلَّا اللَّمَمَ إِنَّ رَبَّكَ وَاسِعُ الْمَغْفِرَةِ هُوَ أَعْلَمُ بِكُمْ إِذْ أَنشَأَكُم مِ͏ّنَ الْأَرْضِ وَإِذْ أَنتُمْ أَجِنَّةٌ فِي بُطُونِ أُمَّهَاتِكُمْ فَلَا تُزَكُّوا أَنفُسَكُمْ هُوَ أَعْلَمُ بِمَنِ اتَّقَىٰ","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":33,"t":"أَفَرَأَيْتَ الَّذِي تَوَلَّىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":34,"t":"وَأَعْطَىٰ قَلِيلًا وَأَكْدَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":35,"t":"أَعِندَهُ عِلْمُ الْغَيْبِ فَهُوَ يَرَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":36,"t":"أَمْ لَمْ يُنَبَّأْ بِمَا فِي صُحُفِ مُوسَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":37,"t":"وَإِبْرَاهِيمَ الَّذِي وَفَّىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":38,"t":"أَلَّا تَزِرُ وَازِرَةٌ وِزْرَ أُخْرَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":39,"t":"وَأَن لَّيْسَ لِلْإِنسَانِ إِلَّا مَا سَعَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":40,"t":"وَأَنَّ سَعْيَهُ سَوْفَ يُرَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":41,"t":"ثُمَّ يُجْزَاهُ الْجَزَاءَ الْأَوْفَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":42,"t":"وَأَنَّ إِلَىٰ رَبِ͏ّكَ الْمُنتَهَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":43,"t":"وَأَنَّهُ هُوَ أَضْحَكَ وَأَبْكَىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":44,"t":"وَأَنَّهُ هُوَ أَمَاتَ وَأَحْيَا","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":45,"t":"وَأَنَّهُ خَلَقَ الزَّوْجَيْنِ الذَّكَرَ وَالْأُنثَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":46,"t":"مِن نُّطْفَةٍ إِذَا تُمْنَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":47,"t":"وَأَنَّ عَلَيْهِ النَّشْأَةَ الْأُخْرَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":48,"t":"وَأَنَّهُ هُوَ أَغْنَىٰ وَأَقْنَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":49,"t":"وَأَنَّهُ هُوَ رَبُّ الشِ͏ّعْرَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":50,"t":"وَأَنَّهُ أَهْلَكَ عَادًا الْأُولَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":51,"t":"وَثَمُودَ فَمَا أَبْقَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":52,"t":"وَقَوْمَ نُوحٍ مِ͏ّن قَبْلُ إِنَّهُمْ كَانُوا هُمْ أَظْلَمَ وَأَطْغَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":53,"t":"وَالْمُؤْتَفِكَةَ أَهْوَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":54,"t":"فَغَشَّاهَا مَا غَشَّىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":55,"t":"فَبِأَيِ͏ّ آلَاءِ رَبِ͏ّكَ تَتَمَارَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":56,"t":"هَٰذَا نَذِيرٌ مِ͏ّنَ النُّذُرِ الْأُولَىٰ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":57,"t":"أَزِفَتِ الْآزِفَةُ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":58,"t":"لَيْسَ لَهَا مِن دُونِ اللَّهِ كَاشِفَةٌ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":59,"t":"أَفَمِنْ هَٰذَا الْحَدِيثِ تَعْجَبُونَ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":60,"t":"وَتَضْحَكُونَ وَلَا تَبْكُونَ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":61,"t":"وَأَنتُمْ سَامِدُونَ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":62,"t":"فَاسْجُدُوا لِلَّهِ وَاعْبُدُوا","p":528,"j":27,"h":211,"rk":462,"m":7,"sj":2}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}