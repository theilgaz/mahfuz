{"verses":[{"v":1,"t":"وَالشَّمْسِ وَضُحَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":2,"t":"وَالْقَمَرِ إِذَا تَلَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":3,"t":"وَالنَّهَارِ إِذَا جَلَّاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":4,"t":"وَاللَّيْلِ إِذَا يَغْشَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":5,"t":"وَالسَّمَاءِ وَمَا بَنَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":6,"t":"وَالْأَرْضِ وَمَا طَحَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":7,"t":"وَنَفْسٍ وَمَا سَوَّاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":8,"t":"فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":9,"t":"قَدْ أَفْلَحَ مَن زَكَّاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":10,"t":"وَقَدْ خَابَ مَن دَسَّاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":11,"t":"كَذَّبَتْ ثَمُودُ بِطَغْوَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":12,"t":"إِذِ انبَعَثَ أَشْقَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":13,"t":"فَقَالَ لَهُمْ رَسُولُ اللَّهِ نَاقَةَ اللَّهِ وَسُقْيَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":14,"t":"فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنبِهِمْ فَسَوَّاهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":15,"t":"وَلَا يَخَافُ عُقْبَاهَا","p":595,"j":30,"h":238,"rk":533,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}