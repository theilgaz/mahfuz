{"verses":[{"v":1,"t":"سَأَلَ سَائِلٌ بِعَذَابٍ وَاقِعٍ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":2,"t":"لِ͏ّلْكَافِرِينَ لَيْسَ لَهُ دَافِعٌ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":3,"t":"مِ͏ّنَ اللَّهِ ذِي الْمَعَارِجِ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":4,"t":"تَعْرُجُ الْمَلَائِكَةُ وَالرُّوحُ إِلَيْهِ فِي يَوْمٍ كَانَ مِقْدَارُهُ خَمْسِينَ أَلْفَ سَنَةٍ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":5,"t":"فَاصْبِرْ صَبْرًا جَمِيلًا","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":6,"t":"إِنَّهُمْ يَرَوْنَهُ بَعِيدًا","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":7,"t":"وَنَرَاهُ قَرِيبًا","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":8,"t":"يَوْمَ تَكُونُ السَّمَاءُ كَالْمُهْلِ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":9,"t":"وَتَكُونُ الْجِبَالُ كَالْعِهْنِ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":10,"t":"وَلَا يَسْأَلُ حَمِيمٌ حَمِيمًا","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":11,"t":"يُبَصَّرُونَهُمْ يَوَدُّ الْمُجْرِمُ لَوْ يَفْتَدِي مِنْ عَذَابِ يَوْمِئِذٍ بِبَنِيهِ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":12,"t":"وَصَاحِبَتِهِ وَأَخِيهِ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":13,"t":"وَفَصِيلَتِهِ الَّتِي تُؤْوِيهِ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":14,"t":"وَمَن فِي الْأَرْضِ جَمِيعًا ثُمَّ يُنجِيهِ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":15,"t":"كَلَّا إِنَّهَا لَظَىٰ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":16,"t":"نَزَّاعَةً لِ͏ّلشَّوَىٰ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":17,"t":"تَدْعُو مَنْ أَدْبَرَ وَتَوَلَّىٰ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":18,"t":"وَجَمَعَ فَأَوْعَىٰ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":19,"t":"إِنَّ الْإِنسَانَ خُلِقَ هَلُوعًا","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":20,"t":"إِذَا مَسَّهُ الشَّرُّ جَزُوعًا","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":21,"t":"وَإِذَا مَسَّهُ الْخَيْرُ مَنُوعًا","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":22,"t":"إِلَّا الْمُصَلِ͏ّينَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":23,"t":"الَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَائِمُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":24,"t":"وَالَّذِينَ فِي أَمْوَالِهِمْ حَقٌّ مَّعْلُومٌ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":25,"t":"لِ͏ّلسَّائِلِ وَالْمَحْرُومِ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":26,"t":"وَالَّذِينَ يُصَدِ͏ّقُونَ بِيَوْمِ الدِ͏ّينِ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":27,"t":"وَالَّذِينَ هُم مِ͏ّنْ عَذَابِ رَبِ͏ّهِم مُّشْفِقُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":28,"t":"إِنَّ عَذَابَ رَبِ͏ّهِمْ غَيْرُ مَأْمُونٍ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":29,"t":"وَالَّذِينَ هُمْ لِفُرُوجِهِمْ حَافِظُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":30,"t":"إِلَّا عَلَىٰ أَزْوَاجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَانُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":31,"t":"فَمَنِ ابْتَغَىٰ وَرَاءَ ذَٰلِكَ فَأُولَٰئِكَ هُمُ الْعَادُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":32,"t":"وَالَّذِينَ هُمْ لِأَمَانَاتِهِمْ وَعَهْدِهِمْ رَاعُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":33,"t":"وَالَّذِينَ هُم بِشَهَادَاتِهِمْ قَائِمُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":34,"t":"وَالَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":35,"t":"أُولَٰئِكَ فِي جَنَّاتٍ مُّكْرَمُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":36,"t":"فَمَالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ","p":569,"j":29,"h":228,"rk":503,"m":7},{"v":37,"t":"عَنِ الْيَمِينِ وَعَنِ الشِ͏ّمَالِ عِزِينَ","p":569,"j":29,"h":228,"rk":503,"m":7},{"v":38,"t":"أَيَطْمَعُ كُلُّ امْرِئٍ مِ͏ّنْهُمْ أَن يُدْخَلَ جَنَّةَ نَعِيمٍ","p":569,"j":29,"h":228,"rk":503,"m":7},{"v":39,"t":"كَلَّا إِنَّا خَلَقْنَاهُم مِ͏ّمَّا يَعْلَمُونَ","p":569,"j":29,"h":228,"rk":503,"m":7},{"v":40,"t":"فَلَا أُقْسِمُ بِرَبِ͏ّ الْمَشَارِقِ وَالْمَغَارِبِ إِنَّا لَقَادِرُونَ","p":570,"j":29,"h":228,"rk":503,"m":7},{"v":41,"t":"عَلَىٰ أَن نُّبَدِ͏ّلَ خَيْرًا مِ͏ّنْهُمْ وَمَا نَحْنُ بِمَسْبُوقِينَ","p":570,"j":29,"h":228,"rk":503,"m":7},{"v":42,"t":"فَذَرْهُمْ يَخُوضُوا وَيَلْعَبُوا حَتَّىٰ يُلَاقُوا يَوْمَهُمُ الَّذِي يُوعَدُونَ","p":570,"j":29,"h":228,"rk":503,"m":7},{"v":43,"t":"يَوْمَ يَخْرُجُونَ مِنَ الْأَجْدَاثِ سِرَاعًا كَأَنَّهُمْ إِلَىٰ نُصُبٍ يُوفِضُونَ","p":570,"j":29,"h":228,"rk":503,"m":7},{"v":44,"t":"خَاشِعَةً أَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ ذَٰلِكَ الْيَوْمُ الَّذِي كَانُوا يُوعَدُونَ","p":570,"j":29,"h":228,"rk":503,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}