{"verses":[{"v":1,"t":"أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَابِ الْفِيلِ","p":601,"j":30,"h":240,"rk":547,"m":7},{"v":2,"t":"أَلَمْ يَجْعَلْ كَيْدَهُمْ فِي تَضْلِيلٍ","p":601,"j":30,"h":240,"rk":547,"m":7},{"v":3,"t":"وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ","p":601,"j":30,"h":240,"rk":547,"m":7},{"v":4,"t":"تَرْمِيهِم بِحِجَارَةٍ مِ͏ّن سِجِ͏ّيلٍ","p":601,"j":30,"h":240,"rk":547,"m":7},{"v":5,"t":"فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍ","p":601,"j":30,"h":240,"rk":547,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}