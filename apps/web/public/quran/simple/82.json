{"verses":[{"v":1,"t":"إِذَا السَّمَاءُ انفَطَرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":2,"t":"وَإِذَا الْكَوَاكِبُ انتَثَرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":3,"t":"وَإِذَا الْبِحَارُ فُجِ͏ّرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":4,"t":"وَإِذَا الْقُبُورُ بُعْثِرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":5,"t":"عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":6,"t":"يَا أَيُّهَا الْإِنسَانُ مَا غَرَّكَ بِرَبِ͏ّكَ الْكَرِيمِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":7,"t":"الَّذِي خَلَقَكَ فَسَوَّاكَ فَعَدَلَكَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":8,"t":"فِي أَيِ͏ّ صُورَةٍ مَّا شَاءَ رَكَّبَكَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":9,"t":"كَلَّا بَلْ تُكَذِ͏ّبُونَ بِالدِ͏ّينِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":10,"t":"وَإِنَّ عَلَيْكُمْ لَحَافِظِينَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":11,"t":"كِرَامًا كَاتِبِينَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":12,"t":"يَعْلَمُونَ مَا تَفْعَلُونَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":13,"t":"إِنَّ الْأَبْرَارَ لَفِي نَعِيمٍ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":14,"t":"وَإِنَّ الْفُجَّارَ لَفِي جَحِيمٍ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":15,"t":"يَصْلَوْنَهَا يَوْمَ الدِ͏ّينِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":16,"t":"وَمَا هُمْ عَنْهَا بِغَائِبِينَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":17,"t":"وَمَا أَدْرَاكَ مَا يَوْمُ الدِ͏ّينِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":18,"t":"ثُمَّ مَا أَدْرَاكَ مَا يَوْمُ الدِ͏ّينِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":19,"t":"يَوْمَ لَا تَمْلِكُ نَفْسٌ لِ͏ّنَفْسٍ شَيْئًا وَالْأَمْرُ يَوْمَئِذٍ لِ͏ّلَّهِ","p":587,"j":30,"h":235,"rk":524,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}