{"verses":[{"v":1,"t":"قُلْ أَعُوذُ بِرَبِ͏ّ النَّاسِ","p":604,"j":30,"h":240,"rk":556,"m":7},{"v":2,"t":"مَلِكِ النَّاسِ","p":604,"j":30,"h":240,"rk":556,"m":7},{"v":3,"t":"إِلَٰهِ النَّاسِ","p":604,"j":30,"h":240,"rk":556,"m":7},{"v":4,"t":"مِن شَرِ͏ّ الْوَسْوَاسِ الْخَنَّاسِ","p":604,"j":30,"h":240,"rk":556,"m":7},{"v":5,"t":"الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ","p":604,"j":30,"h":240,"rk":556,"m":7},{"v":6,"t":"مِنَ الْجِنَّةِ وَالنَّاسِ","p":604,"j":30,"h":240,"rk":556,"m":7}],"bismillah":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"}