{"verses":[{"v":1,"t":"طسم","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":2,"t":"تِلْكَ آيَاتُ الْكِتَابِ الْمُبِينِ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":3,"t":"لَعَلَّكَ بَاخِعٌ نَّفْسَكَ أَلَّا يَكُونُوا مُؤْمِنِينَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":4,"t":"إِن نَّشَأْ نُنَزِ͏ّلْ عَلَيْهِم مِ͏ّنَ السَّمَاءِ آيَةً فَظَلَّتْ أَعْنَاقُهُمْ لَهَا خَاضِعِينَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":5,"t":"وَمَا يَأْتِيهِم مِ͏ّن ذِكْرٍ مِ͏ّنَ الرَّحْمَٰنِ مُحْدَثٍ إِلَّا كَانُوا عَنْهُ مُعْرِضِينَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":6,"t":"فَقَدْ كَذَّبُوا فَسَيَأْتِيهِمْ أَنبَاءُ مَا كَانُوا بِهِ يَسْتَهْزِئُونَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":7,"t":"أَوَلَمْ يَرَوْا إِلَى الْأَرْضِ كَمْ أَنبَتْنَا فِيهَا مِن كُلِ͏ّ زَوْجٍ كَرِيمٍ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":8,"t":"إِنَّ فِي ذَٰلِكَ لَآيَةً وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":9,"t":"وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":10,"t":"وَإِذْ نَادَىٰ رَبُّكَ مُوسَىٰ أَنِ ائْتِ الْقَوْمَ الظَّالِمِينَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":11,"t":"قَوْمَ فِرْعَوْنَ أَلَا يَتَّقُونَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":12,"t":"قَالَ رَبِ͏ّ إِنِ͏ّي أَخَافُ أَن يُكَذِ͏ّبُونِ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":13,"t":"وَيَضِيقُ صَدْرِي وَلَا يَنطَلِقُ لِسَانِي فَأَرْسِلْ إِلَىٰ هَارُونَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":14,"t":"وَلَهُمْ عَلَيَّ ذَنبٌ فَأَخَافُ أَن يَقْتُلُونِ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":15,"t":"قَالَ كَلَّا فَاذْهَبَا بِآيَاتِنَا إِنَّا مَعَكُم مُّسْتَمِعُونَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":16,"t":"فَأْتِيَا فِرْعَوْنَ فَقُولَا إِنَّا رَسُولُ رَبِ͏ّ الْعَالَمِينَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":17,"t":"أَنْ أَرْسِلْ مَعَنَا بَنِي إِسْرَائِيلَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":18,"t":"قَالَ أَلَمْ نُرَبِ͏ّكَ فِينَا وَلِيدًا وَلَبِثْتَ فِينَا مِنْ عُمُرِكَ سِنِينَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":19,"t":"وَفَعَلْتَ فَعْلَتَكَ الَّتِي فَعَلْتَ وَأَنتَ مِنَ الْكَافِرِينَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":20,"t":"قَالَ فَعَلْتُهَا إِذًا وَأَنَا مِنَ الضَّالِ͏ّينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":21,"t":"فَفَرَرْتُ مِنكُمْ لَمَّا خِفْتُكُمْ فَوَهَبَ لِي رَبِ͏ّي حُكْمًا وَجَعَلَنِي مِنَ الْمُرْسَلِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":22,"t":"وَتِلْكَ نِعْمَةٌ تَمُنُّهَا عَلَيَّ أَنْ عَبَّدتَّ بَنِي إِسْرَائِيلَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":23,"t":"قَالَ فِرْعَوْنُ وَمَا رَبُّ الْعَالَمِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":24,"t":"قَالَ رَبُّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا إِن كُنتُم مُّوقِنِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":25,"t":"قَالَ لِمَنْ حَوْلَهُ أَلَا تَسْتَمِعُونَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":26,"t":"قَالَ رَبُّكُمْ وَرَبُّ آبَائِكُمُ الْأَوَّلِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":27,"t":"قَالَ إِنَّ رَسُولَكُمُ الَّذِي أُرْسِلَ إِلَيْكُمْ لَمَجْنُونٌ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":28,"t":"قَالَ رَبُّ الْمَشْرِقِ وَالْمَغْرِبِ وَمَا بَيْنَهُمَا إِن كُنتُمْ تَعْقِلُونَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":29,"t":"قَالَ لَئِنِ اتَّخَذْتَ إِلَٰهًا غَيْرِي لَأَجْعَلَنَّكَ مِنَ الْمَسْجُونِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":30,"t":"قَالَ أَوَلَوْ جِئْتُكَ بِشَيْءٍ مُّبِينٍ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":31,"t":"قَالَ فَأْتِ بِهِ إِن كُنتَ مِنَ الصَّادِقِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":32,"t":"فَأَلْقَىٰ عَصَاهُ فَإِذَا هِيَ ثُعْبَانٌ مُّبِينٌ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":33,"t":"وَنَزَعَ يَدَهُ فَإِذَا هِيَ بَيْضَاءُ لِلنَّاظِرِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":34,"t":"قَالَ لِلْمَلَإِ حَوْلَهُ إِنَّ هَٰذَا لَسَاحِرٌ عَلِيمٌ","p":368,"j":19,"h":147,"rk":318,"m":5},{"v":35,"t":"يُرِيدُ أَن يُخْرِجَكُم مِ͏ّنْ أَرْضِكُم بِسِحْرِهِ فَمَاذَا تَأْمُرُونَ","p":368,"j":19,"h":147,"rk":318,"m":5},{"v":36,"t":"قَالُوا أَرْجِهْ وَأَخَاهُ وَابْعَثْ فِي الْمَدَائِنِ حَاشِرِينَ","p":368,"j":19,"h":147,"rk":318,"m":5},{"v":37,"t":"يَأْتُوكَ بِكُلِ͏ّ سَحَّارٍ عَلِيمٍ","p":368,"j":19,"h":147,"rk":318,"m":5},{"v":38,"t":"فَجُمِعَ السَّحَرَةُ لِمِيقَاتِ يَوْمٍ مَّعْلُومٍ","p":368,"j":19,"h":147,"rk":318,"m":5},{"v":39,"t":"وَقِيلَ لِلنَّاسِ هَلْ أَنتُم مُّجْتَمِعُونَ","p":368,"j":19,"h":147,"rk":318,"m":5},{"v":40,"t":"لَعَلَّنَا نَتَّبِعُ السَّحَرَةَ إِن كَانُوا هُمُ الْغَالِبِينَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":41,"t":"فَلَمَّا جَاءَ السَّحَرَةُ قَالُوا لِفِرْعَوْنَ أَئِنَّ لَنَا لَأَجْرًا إِن كُنَّا نَحْنُ الْغَالِبِينَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":42,"t":"قَالَ نَعَمْ وَإِنَّكُمْ إِذًا لَّمِنَ الْمُقَرَّبِينَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":43,"t":"قَالَ لَهُم مُّوسَىٰ أَلْقُوا مَا أَنتُم مُّلْقُونَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":44,"t":"فَأَلْقَوْا حِبَالَهُمْ وَعِصِيَّهُمْ وَقَالُوا بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ الْغَالِبُونَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":45,"t":"فَأَلْقَىٰ مُوسَىٰ عَصَاهُ فَإِذَا هِيَ تَلْقَفُ مَا يَأْفِكُونَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":46,"t":"فَأُلْقِيَ السَّحَرَةُ سَاجِدِينَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":47,"t":"قَالُوا آمَنَّا بِرَبِ͏ّ الْعَالَمِينَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":48,"t":"رَبِ͏ّ مُوسَىٰ وَهَارُونَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":49,"t":"قَالَ آمَنتُمْ لَهُ قَبْلَ أَنْ آذَنَ لَكُمْ إِنَّهُ لَكَبِيرُكُمُ الَّذِي عَلَّمَكُمُ السِ͏ّحْرَ فَلَسَوْفَ تَعْلَمُونَ لَأُقَطِ͏ّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِ͏ّنْ خِلَافٍ وَلَأُصَلِ͏ّبَنَّكُمْ أَجْمَعِينَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":50,"t":"قَالُوا لَا ضَيْرَ إِنَّا إِلَىٰ رَبِ͏ّنَا مُنقَلِبُونَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":51,"t":"إِنَّا نَطْمَعُ أَن يَغْفِرَ لَنَا رَبُّنَا خَطَايَانَا أَن كُنَّا أَوَّلَ الْمُؤْمِنِينَ","p":369,"j":19,"h":147,"rk":318,"m":5},{"v":52,"t":"وَأَوْحَيْنَا إِلَىٰ مُوسَىٰ أَنْ أَسْرِ بِعِبَادِي إِنَّكُم مُّتَّبَعُ