{"verses":[{"v":1,"t":"لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَٰمَةِ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":2,"t":"وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":3,"t":"أَيَحْسَبُ ٱلْإِنسَٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":4,"t":"بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِ͏ّىَ بَنَانَهُۥ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":5,"t":"بَلْ يُرِيدُ ٱلْإِنسَٰنُ لِيَفْجُرَ أَمَامَهُۥ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":6,"t":"يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَٰمَةِ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":7,"t":"فَإِذَا بَرِقَ ٱلْبَصَرُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":8,"t":"وَخَسَفَ ٱلْقَمَرُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":9,"t":"وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":10,"t":"يَقُولُ ٱلْإِنسَٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":11,"t":"كَلَّا لَا وَزَرَ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":12,"t":"إِلَىٰ رَبِ͏ّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":13,"t":"يُنَبَّؤُا۟ ٱلْإِنسَٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":14,"t":"بَلِ ٱلْإِنسَٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":15,"t":"وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":16,"t":"لَا تُحَرِ͏ّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":17,"t":"إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":18,"t":"فَإِذَا قَرَأْنَٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":19,"t":"ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ","p":577,"j":29,"h":231,"rk":512,"m":7},{"v":20,"t":"كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":21,"t":"وَتَذَرُونَ ٱلْـَٔاخِرَةَ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":22,"t":"وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":23,"t":"إِلَىٰ رَبِ͏ّهَا نَاظِرَةٌ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":24,"t":"وَوُجُوهٌ يَوْمَئِذٍۭ بَاسِرَةٌ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":25,"t":"تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":26,"t":"كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":27,"t":"وَقِيلَ مَنْ رَاقٍ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":28,"t":"وَظَنَّ أَنَّهُ ٱلْفِرَاقُ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":29,"t":"وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":30,"t":"إِلَىٰ رَبِ͏ّكَ يَوْمَئِذٍ ٱلْمَسَاقُ","p":578,"j":29,"h":231,"rk":512,"m":7},{"v":31,"t":"فَلَا صَدَّقَ وَلَا صَلَّىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":32,"t":"وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":33,"t":"ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":34,"t":"أَوْلَىٰ لَكَ فَأَوْلَىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":35,"t":"ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":36,"t":"أَيَحْسَبُ ٱلْإِنسَٰنُ أَن يُتْرَكَ سُدًى","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":37,"t":"أَلَمْ يَكُ نُطْفَةً مِ͏ّن مَّنِىٍّ يُمْنَىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":38,"t":"ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":39,"t":"فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ","p":578,"j":29,"h":231,"rk":513,"m":7},{"v":40,"t":"أَلَيْسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰٓ أَن يُحْـِۧىَ ٱلْمَوْتَىٰ","p":578,"j":29,"h":231,"rk":513,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}