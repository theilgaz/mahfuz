{"verses":[{"v":1,"t":"إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":2,"t":"وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":3,"t":"وَإِذَا ٱلْبِحَارُ فُجِ͏ّرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":4,"t":"وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":5,"t":"عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":6,"t":"يَٰٓأَيُّهَا ٱلْإِنسَٰنُ مَا غَرَّكَ بِرَبِ͏ّكَ ٱلْكَرِيمِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":7,"t":"ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":8,"t":"فِىٓ أَىِ͏ّ صُورَةٍ مَّا شَآءَ رَكَّبَكَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":9,"t":"كَلَّا بَلْ تُكَذِ͏ّبُونَ بِٱلدِ͏ّينِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":10,"t":"وَإِنَّ عَلَيْكُمْ لَحَٰفِظِينَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":11,"t":"كِرَامًا كَٰتِبِينَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":12,"t":"يَعْلَمُونَ مَا تَفْعَلُونَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":13,"t":"إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":14,"t":"وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":15,"t":"يَصْلَوْنَهَا يَوْمَ ٱلدِ͏ّينِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":16,"t":"وَمَا هُمْ عَنْهَا بِغَآئِبِينَ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":17,"t":"وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِ͏ّينِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":18,"t":"ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِ͏ّينِ","p":587,"j":30,"h":235,"rk":524,"m":7},{"v":19,"t":"يَوْمَ لَا تَمْلِكُ نَفْسٌ لِ͏ّنَفْسٍ شَيْـًٔا وَٱلْأَمْرُ يَوْمَئِذٍ لِ͏ّلَّهِ","p":587,"j":30,"h":235,"rk":524,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}