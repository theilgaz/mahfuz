{"verses":[{"v":1,"t":"ٱلْحَآقَّةُ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":2,"t":"مَا ٱلْحَآقَّةُ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":3,"t":"وَمَآ أَدْرَىٰكَ مَا ٱلْحَآقَّةُ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":4,"t":"كَذَّبَتْ ثَمُودُ وَعَادٌۢ بِٱلْقَارِعَةِ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":5,"t":"فَأَمَّا ثَمُودُ فَأُهْلِكُوا۟ بِٱلطَّاغِيَةِ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":6,"t":"وَأَمَّا عَادٌ فَأُهْلِكُوا۟ بِرِيحٍ صَرْصَرٍ عَاتِيَةٍ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":7,"t":"سَخَّرَهَا عَلَيْهِمْ سَبْعَ لَيَالٍ وَثَمَٰنِيَةَ أَيَّامٍ حُسُومًا فَتَرَى ٱلْقَوْمَ فِيهَا صَرْعَىٰ كَأَنَّهُمْ أَعْجَازُ نَخْلٍ خَاوِيَةٍ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":8,"t":"فَهَلْ تَرَىٰ لَهُم مِ͏ّنۢ بَاقِيَةٍ","p":566,"j":29,"h":227,"rk":500,"m":7},{"v":9,"t":"وَجَآءَ فِرْعَوْنُ وَمَن قَبْلَهُۥ وَٱلْمُؤْتَفِكَٰتُ بِٱلْخَاطِئَةِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":10,"t":"فَعَصَوْا۟ رَسُولَ رَبِ͏ّهِمْ فَأَخَذَهُمْ أَخْذَةً رَّابِيَةً","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":11,"t":"إِنَّا لَمَّا طَغَا ٱلْمَآءُ حَمَلْنَٰكُمْ فِى ٱلْجَارِيَةِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":12,"t":"لِنَجْعَلَهَا لَكُمْ تَذْكِرَةً وَتَعِيَهَآ أُذُنٌ وَٰعِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":13,"t":"فَإِذَا نُفِخَ فِى ٱلصُّورِ نَفْخَةٌ وَٰحِدَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":14,"t":"وَحُمِلَتِ ٱلْأَرْضُ وَٱلْجِبَالُ فَدُكَّتَا دَكَّةً وَٰحِدَةً","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":15,"t":"فَيَوْمَئِذٍ وَقَعَتِ ٱلْوَاقِعَةُ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":16,"t":"وَٱنشَقَّتِ ٱلسَّمَآءُ فَهِىَ يَوْمَئِذٍ وَاهِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":17,"t":"وَٱلْمَلَكُ عَلَىٰٓ أَرْجَآئِهَا وَيَحْمِلُ عَرْشَ رَبِ͏ّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمَٰنِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":18,"t":"يَوْمَئِذٍ تُعْرَضُونَ لَا تَخْفَىٰ مِنكُمْ خَافِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":19,"t":"فَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ بِيَمِينِهِۦ فَيَقُولُ هَآؤُمُ ٱقْرَءُوا۟ كِتَٰبِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":20,"t":"إِنِ͏ّى ظَنَنتُ أَنِ͏ّى مُلَٰقٍ حِسَابِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":21,"t":"فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":22,"t":"فِى جَنَّةٍ عَالِيَةٍ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":23,"t":"قُطُوفُهَا دَانِيَةٌ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":24,"t":"كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَآ أَسْلَفْتُمْ فِى ٱلْأَيَّامِ ٱلْخَالِيَةِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":25,"t":"وَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ بِشِمَالِهِۦ فَيَقُولُ يَٰلَيْتَنِى لَمْ أُوتَ كِتَٰبِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":26,"t":"وَلَمْ أَدْرِ مَا حِسَابِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":27,"t":"يَٰلَيْتَهَا كَانَتِ ٱلْقَاضِيَةَ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":28,"t":"مَآ أَغْنَىٰ عَنِ͏ّى مَالِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":29,"t":"هَلَكَ عَنِ͏ّى سُلْطَٰنِيَهْ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":30,"t":"خُذُوهُ فَغُلُّوهُ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":31,"t":"ثُمَّ ٱلْجَحِيمَ صَلُّوهُ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":32,"t":"ثُمَّ فِى سِلْسِلَةٍ ذَرْعُهَا سَبْعُونَ ذِرَاعًا فَٱسْلُكُوهُ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":33,"t":"إِنَّهُۥ كَانَ لَا يُؤْمِنُ بِٱللَّهِ ٱلْعَظِيمِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":34,"t":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","p":567,"j":29,"h":227,"rk":500,"m":7},{"v":35,"t":"فَلَيْسَ لَهُ ٱلْيَوْمَ هَٰهُنَا حَمِيمٌ","p":568,"j":29,"h":227,"rk":500,"m":7},{"v":36,"t":"وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍ","p":568,"j":29,"h":227,"rk":500,"m":7},{"v":37,"t":"لَّا يَأْكُلُهُۥٓ إِلَّا ٱلْخَٰطِـُٔونَ","p":568,"j":29,"h":227,"rk":500,"m":7},{"v":38,"t":"فَلَآ أُقْسِمُ بِمَا تُبْصِرُونَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":39,"t":"وَمَا لَا تُبْصِرُونَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":40,"t":"إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":41,"t":"وَمَا هُوَ بِقَوْلِ شَاعِرٍ قَلِيلًا مَّا تُؤْمِنُونَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":42,"t":"وَلَا بِقَوْلِ كَاهِنٍ قَلِيلًا مَّا تَذَكَّرُونَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":43,"t":"تَنزِيلٌ مِ͏ّن رَّبِ͏ّ ٱلْعَٰلَمِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":44,"t":"وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ ٱلْأَقَاوِيلِ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":45,"t":"لَأَخَذْنَا مِنْهُ بِٱلْيَمِينِ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":46,"t":"ثُمَّ لَقَطَعْنَا مِنْهُ ٱلْوَتِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":47,"t":"فَمَا مِنكُم مِ͏ّنْ أَحَدٍ عَنْهُ حَٰجِزِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":48,"t":"وَإِنَّهُۥ لَتَذْكِرَةٌ لِ͏ّلْمُتَّقِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":49,"t":"وَإِنَّا لَنَعْلَمُ أَنَّ مِنكُم مُّكَذِ͏ّبِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":50,"t":"وَإِنَّهُۥ لَحَسْرَةٌ عَلَى ٱلْكَٰفِرِينَ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":51,"t":"وَإِنَّهُۥ لَحَقُّ ٱلْيَقِينِ","p":568,"j":29,"h":227,"rk":501,"m":7},{"v":52,"t":"فَسَبِ͏ّحْ بِٱسْمِ رَبِ͏ّكَ ٱلْعَظِيمِ","p":568,"j":29,"h":227,"rk":501,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}