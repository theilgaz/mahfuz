{"verses":[{"v":1,"t":"طسٓمٓ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":2,"t":"تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ ٱلْمُبِينِ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":3,"t":"لَعَلَّكَ بَٰخِعٌ نَّفْسَكَ أَلَّا يَكُونُوا۟ مُؤْمِنِينَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":4,"t":"إِن نَّشَأْ نُنَزِ͏ّلْ عَلَيْهِم مِ͏ّنَ ٱلسَّمَآءِ ءَايَةً فَظَلَّتْ أَعْنَٰقُهُمْ لَهَا خَٰضِعِينَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":5,"t":"وَمَا يَأْتِيهِم مِ͏ّن ذِكْرٍ مِ͏ّنَ ٱلرَّحْمَٰنِ مُحْدَثٍ إِلَّا كَانُوا۟ عَنْهُ مُعْرِضِينَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":6,"t":"فَقَدْ كَذَّبُوا۟ فَسَيَأْتِيهِمْ أَنۢبَٰٓؤُا۟ مَا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":7,"t":"أَوَلَمْ يَرَوْا۟ إِلَى ٱلْأَرْضِ كَمْ أَنۢبَتْنَا فِيهَا مِن كُلِ͏ّ زَوْجٍ كَرِيمٍ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":8,"t":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":9,"t":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","p":367,"j":19,"h":147,"rk":316,"m":5},{"v":10,"t":"وَإِذْ نَادَىٰ رَبُّكَ مُوسَىٰٓ أَنِ ٱئْتِ ٱلْقَوْمَ ٱلظَّٰلِمِينَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":11,"t":"قَوْمَ فِرْعَوْنَ أَلَا يَتَّقُونَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":12,"t":"قَالَ رَبِ͏ّ إِنِ͏ّىٓ أَخَافُ أَن يُكَذِ͏ّبُونِ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":13,"t":"وَيَضِيقُ صَدْرِى وَلَا يَنطَلِقُ لِسَانِى فَأَرْسِلْ إِلَىٰ هَٰرُونَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":14,"t":"وَلَهُمْ عَلَىَّ ذَنۢبٌ فَأَخَافُ أَن يَقْتُلُونِ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":15,"t":"قَالَ كَلَّا فَٱذْهَبَا بِـَٔايَٰتِنَآ إِنَّا مَعَكُم مُّسْتَمِعُونَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":16,"t":"فَأْتِيَا فِرْعَوْنَ فَقُولَآ إِنَّا رَسُولُ رَبِ͏ّ ٱلْعَٰلَمِينَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":17,"t":"أَنْ أَرْسِلْ مَعَنَا بَنِىٓ إِسْرَٰٓءِيلَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":18,"t":"قَالَ أَلَمْ نُرَبِ͏ّكَ فِينَا وَلِيدًا وَلَبِثْتَ فِينَا مِنْ عُمُرِكَ سِنِينَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":19,"t":"وَفَعَلْتَ فَعْلَتَكَ ٱلَّتِى فَعَلْتَ وَأَنتَ مِنَ ٱلْكَٰفِرِينَ","p":367,"j":19,"h":147,"rk":317,"m":5},{"v":20,"t":"قَالَ فَعَلْتُهَآ إِذًا وَأَنَا۠ مِنَ ٱلضَّآلِ͏ّينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":21,"t":"فَفَرَرْتُ مِنكُمْ لَمَّا خِفْتُكُمْ فَوَهَبَ لِى رَبِ͏ّى حُكْمًا وَجَعَلَنِى مِنَ ٱلْمُرْسَلِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":22,"t":"وَتِلْكَ نِعْمَةٌ تَمُنُّهَا عَلَىَّ أَنْ عَبَّدتَّ بَنِىٓ إِسْرَٰٓءِيلَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":23,"t":"قَالَ فِرْعَوْنُ وَمَا رَبُّ ٱلْعَٰلَمِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":24,"t":"قَالَ رَبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَآ إِن كُنتُم مُّوقِنِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":25,"t":"قَالَ لِمَنْ حَوْلَهُۥٓ أَلَا تَسْتَمِعُونَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":26,"t":"قَالَ رَبُّكُمْ وَرَبُّ ءَابَآئِكُمُ ٱلْأَوَّلِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":27,"t":"قَالَ إِنَّ رَسُولَكُمُ ٱلَّذِىٓ أُرْسِلَ إِلَيْكُمْ لَمَجْنُونٌ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":28,"t":"قَالَ رَبُّ ٱلْمَشْرِقِ وَٱلْمَغْرِبِ وَمَا بَيْنَهُمَآ إِن كُنتُمْ تَعْقِلُونَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":29,"t":"قَالَ لَئِنِ ٱتَّخَذْتَ إِلَٰهًا غَيْرِى لَأَجْعَلَنَّكَ مِنَ ٱلْمَسْجُونِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":30,"t":"قَالَ أَوَلَوْ جِئْتُكَ بِشَىْءٍ مُّبِينٍ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":31,"t":"قَالَ فَأْتِ بِهِۦٓ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":32,"t":"فَأَلْقَىٰ عَصَاهُ فَإِذَا هِىَ ثُعْبَانٌ مُّبِينٌ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":33,"t":"وَنَزَعَ يَدَهُۥ فَإِذَا هِىَ بَيْضَآءُ لِلنَّٰظِرِينَ","p":368,"j":19,"h":147,"rk":317,"m":5},{"v":34,"t":"قَالَ لِلْمَلَإِ حَوْلَهُۥٓ إِنَّ هَٰذَا لَسَٰحِرٌ عَلِيمٌ","p":368,"j":19,"h":147,"rk":318,"m":5},{"v":35,"t":"يُرِيدُ أَن يُخْرِجَكُم مِ͏ّنْ أَرْضِكُم بِسِحْرِهِۦ فَمَاذَا تَأْمُرُونَ","p":368,"j":1