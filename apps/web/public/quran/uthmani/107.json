{"verses":[{"v":1,"t":"أَرَءَيْتَ ٱلَّذِى يُكَذِ͏ّبُ بِٱلدِ͏ّينِ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":2,"t":"فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":3,"t":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":4,"t":"فَوَيْلٌ لِ͏ّلْمُصَلِ͏ّينَ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":5,"t":"ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":6,"t":"ٱلَّذِينَ هُمْ يُرَآءُونَ","p":602,"j":30,"h":240,"rk":549,"m":7},{"v":7,"t":"وَيَمْنَعُونَ ٱلْمَاعُونَ","p":602,"j":30,"h":240,"rk":549,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}