{"verses":[{"v":1,"t":"وَيْلٌ لِ͏ّلْمُطَفِ͏ّفِينَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":2,"t":"ٱلَّذِينَ إِذَا ٱكْتَالُوا۟ عَلَى ٱلنَّاسِ يَسْتَوْفُونَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":3,"t":"وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":4,"t":"أَلَا يَظُنُّ أُو۟لَٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":5,"t":"لِيَوْمٍ عَظِيمٍ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":6,"t":"يَوْمَ يَقُومُ ٱلنَّاسُ لِرَبِ͏ّ ٱلْعَٰلَمِينَ","p":587,"j":30,"h":235,"rk":525,"m":7},{"v":7,"t":"كَلَّآ إِنَّ كِتَٰبَ ٱلْفُجَّارِ لَفِى سِجِ͏ّينٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":8,"t":"وَمَآ أَدْرَىٰكَ مَا سِجِ͏ّينٌ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":9,"t":"كِتَٰبٌ مَّرْقُومٌ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":10,"t":"وَيْلٌ يَوْمَئِذٍ لِ͏ّلْمُكَذِ͏ّبِينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":11,"t":"ٱلَّذِينَ يُكَذِ͏ّبُونَ بِيَوْمِ ٱلدِ͏ّينِ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":12,"t":"وَمَا يُكَذِ͏ّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":13,"t":"إِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلْأَوَّلِينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":14,"t":"كَلَّا بَلْ رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُوا۟ يَكْسِبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":15,"t":"كَلَّآ إِنَّهُمْ عَن رَّبِ͏ّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":16,"t":"ثُمَّ إِنَّهُمْ لَصَالُوا۟ ٱلْجَحِيمِ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":17,"t":"ثُمَّ يُقَالُ هَٰذَا ٱلَّذِى كُنتُم بِهِۦ تُكَذِ͏ّبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":18,"t":"كَلَّآ إِنَّ كِتَٰبَ ٱلْأَبْرَارِ لَفِى عِلِ͏ّيِ͏ّينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":19,"t":"وَمَآ أَدْرَىٰكَ مَا عِلِ͏ّيُّونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":20,"t":"كِتَٰبٌ مَّرْقُومٌ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":21,"t":"يَشْهَدُهُ ٱلْمُقَرَّبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":22,"t":"إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":23,"t":"عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":24,"t":"تَعْرِفُ فِى وُجُوهِهِمْ نَضْرَةَ ٱلنَّعِيمِ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":25,"t":"يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":26,"t":"خِتَٰمُهُۥ مِسْكٌ وَفِى ذَٰلِكَ فَلْيَتَنَافَسِ ٱلْمُتَنَٰفِسُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":27,"t":"وَمِزَاجُهُۥ مِن تَسْنِيمٍ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":28,"t":"عَيْنًا يَشْرَبُ بِهَا ٱلْمُقَرَّبُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":29,"t":"إِنَّ ٱلَّذِينَ أَجْرَمُوا۟ كَانُوا۟ مِنَ ٱلَّذِينَ ءَامَنُوا۟ يَضْحَكُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":30,"t":"وَإِذَا مَرُّوا۟ بِهِمْ يَتَغَامَزُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":31,"t":"وَإِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمُ ٱنقَلَبُوا۟ فَكِهِينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":32,"t":"وَإِذَا رَأَوْهُمْ قَالُوٓا۟ إِنَّ هَٰٓؤُلَآءِ لَضَآلُّونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":33,"t":"وَمَآ أُرْسِلُوا۟ عَلَيْهِمْ حَٰفِظِينَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":34,"t":"فَٱلْيَوْمَ ٱلَّذِينَ ءَامَنُوا۟ مِنَ ٱلْكُفَّارِ يَضْحَكُونَ","p":588,"j":30,"h":235,"rk":525,"m":7},{"v":35,"t":"عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ","p":589,"j":30,"h":235,"rk":525,"m":7},{"v":36,"t":"هَلْ ثُوِ͏ّبَ ٱلْكُفَّارُ مَا كَانُوا۟ يَفْعَلُونَ","p":589,"j":30,"h":235,"rk":525,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}