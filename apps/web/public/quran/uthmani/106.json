{"verses":[{"v":1,"t":"لِإِيلَٰفِ قُرَيْشٍ","p":602,"j":30,"h":240,"rk":548,"m":7},{"v":2,"t":"إِۦلَٰفِهِمْ رِحْلَةَ ٱلشِ͏ّتَآءِ وَٱلصَّيْفِ","p":602,"j":30,"h":240,"rk":548,"m":7},{"v":3,"t":"فَلْيَعْبُدُوا۟ رَبَّ هَٰذَا ٱلْبَيْتِ","p":602,"j":30,"h":240,"rk":548,"m":7},{"v":4,"t":"ٱلَّذِىٓ أَطْعَمَهُم مِ͏ّن جُوعٍ وَءَامَنَهُم مِ͏ّنْ خَوْفٍۭ","p":602,"j":30,"h":240,"rk":548,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}