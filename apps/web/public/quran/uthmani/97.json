{"verses":[{"v":1,"t":"إِنَّآ أَنزَلْنَٰهُ فِى لَيْلَةِ ٱلْقَدْرِ","p":598,"j":30,"h":239,"rk":539,"m":7},{"v":2,"t":"وَمَآ أَدْرَىٰكَ مَا لَيْلَةُ ٱلْقَدْرِ","p":598,"j":30,"h":239,"rk":539,"m":7},{"v":3,"t":"لَيْلَةُ ٱلْقَدْرِ خَيْرٌ مِ͏ّنْ أَلْفِ شَهْرٍ","p":598,"j":30,"h":239,"rk":539,"m":7},{"v":4,"t":"تَنَزَّلُ ٱلْمَلَٰٓئِكَةُ وَٱلرُّوحُ فِيهَا بِإِذْنِ رَبِ͏ّهِم مِ͏ّن كُلِ͏ّ أَمْرٍ","p":598,"j":30,"h":239,"rk":539,"m":7},{"v":5,"t":"سَلَٰمٌ هِىَ حَتَّىٰ مَطْلَعِ ٱلْفَجْرِ","p":598,"j":30,"h":239,"rk":539,"m":7}],"bismillah":"بِ͏ّسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}