{"verses":[{"v":1,"t":"وَيْلٌ لِ͏ّكُلِ͏ّ هُمَزَةٍ لُّمَزَةٍ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":2,"t":"ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":3,"t":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":4,"t":"كَلَّا لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":5,"t":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":6,"t":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":7,"t":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":8,"t":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ","p":601,"j":30,"h":240,"rk":546,"m":7},{"v":9,"t":"فِى عَمَدٍ مُّمَدَّدَةٍۭ","p":601,"j":30,"h":240,"rk":546,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}