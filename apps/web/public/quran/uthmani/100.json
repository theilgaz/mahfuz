{"verses":[{"v":1,"t":"وَٱلْعَٰدِيَٰتِ ضَبْحًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":2,"t":"فَٱلْمُورِيَٰتِ قَدْحًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":3,"t":"فَٱلْمُغِيرَٰتِ صُبْحًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":4,"t":"فَأَثَرْنَ بِهِۦ نَقْعًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":5,"t":"فَوَسَطْنَ بِهِۦ جَمْعًا","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":6,"t":"إِنَّ ٱلْإِنسَٰنَ لِرَبِ͏ّهِۦ لَكَنُودٌ","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":7,"t":"وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":8,"t":"وَإِنَّهُۥ لِحُبِ͏ّ ٱلْخَيْرِ لَشَدِيدٌ","p":599,"j":30,"h":239,"rk":542,"m":7},{"v":9,"t":"أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ","p":599,"j":30,"h":240,"rk":542,"m":7},{"v":10,"t":"وَحُصِ͏ّلَ مَا فِى ٱلصُّدُورِ","p":600,"j":30,"h":240,"rk":542,"m":7},{"v":11,"t":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ","p":600,"j":30,"h":240,"rk":542,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}