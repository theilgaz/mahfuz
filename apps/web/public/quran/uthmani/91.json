{"verses":[{"v":1,"t":"وَٱلشَّمْسِ وَضُحَىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":2,"t":"وَٱلْقَمَرِ إِذَا تَلَىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":3,"t":"وَٱلنَّهَارِ إِذَا جَلَّىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":4,"t":"وَٱلَّيْلِ إِذَا يَغْشَىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":5,"t":"وَٱلسَّمَآءِ وَمَا بَنَىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":6,"t":"وَٱلْأَرْضِ وَمَا طَحَىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":7,"t":"وَنَفْسٍ وَمَا سَوَّىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":8,"t":"فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":9,"t":"قَدْ أَفْلَحَ مَن زَكَّىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":10,"t":"وَقَدْ خَابَ مَن دَسَّىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":11,"t":"كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":12,"t":"إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":13,"t":"فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":14,"t":"فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّىٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7},{"v":15,"t":"وَلَا يَخَافُ عُقْبَٰهَا","p":595,"j":30,"h":238,"rk":533,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}