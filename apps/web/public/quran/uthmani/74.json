{"verses":[{"v":1,"t":"يَٰٓأَيُّهَا ٱلْمُدَّثِ͏ّرُ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":2,"t":"قُمْ فَأَنذِرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":3,"t":"وَرَبَّكَ فَكَبِ͏ّرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":4,"t":"وَثِيَابَكَ فَطَهِ͏ّرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":5,"t":"وَٱلرُّجْزَ فَٱهْجُرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":6,"t":"وَلَا تَمْنُن تَسْتَكْثِرُ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":7,"t":"وَلِرَبِ͏ّكَ فَٱصْبِرْ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":8,"t":"فَإِذَا نُقِرَ فِى ٱلنَّاقُورِ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":9,"t":"فَذَٰلِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":10,"t":"عَلَى ٱلْكَٰفِرِينَ غَيْرُ يَسِيرٍ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":11,"t":"ذَرْنِى وَمَنْ خَلَقْتُ وَحِيدًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":12,"t":"وَجَعَلْتُ لَهُۥ مَالًا مَّمْدُودًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":13,"t":"وَبَنِينَ شُهُودًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":14,"t":"وَمَهَّدتُّ لَهُۥ تَمْهِيدًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":15,"t":"ثُمَّ يَطْمَعُ أَنْ أَزِيدَ","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":16,"t":"كَلَّآ إِنَّهُۥ كَانَ لِـَٔايَٰتِنَا عَنِيدًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":17,"t":"سَأُرْهِقُهُۥ صَعُودًا","p":575,"j":29,"h":230,"rk":510,"m":7},{"v":18,"t":"إِنَّهُۥ فَكَّرَ وَقَدَّرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":19,"t":"فَقُتِلَ كَيْفَ قَدَّرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":20,"t":"ثُمَّ قُتِلَ كَيْفَ قَدَّرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":21,"t":"ثُمَّ نَظَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":22,"t":"ثُمَّ عَبَسَ وَبَسَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":23,"t":"ثُمَّ أَدْبَرَ وَٱسْتَكْبَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":24,"t":"فَقَالَ إِنْ هَٰذَآ إِلَّا سِحْرٌ يُؤْثَرُ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":25,"t":"إِنْ هَٰذَآ إِلَّا قَوْلُ ٱلْبَشَرِ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":26,"t":"سَأُصْلِيهِ سَقَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":27,"t":"وَمَآ أَدْرَىٰكَ مَا سَقَرُ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":28,"t":"لَا تُبْقِى وَلَا تَذَرُ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":29,"t":"لَوَّاحَةٌ لِ͏ّلْبَشَرِ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":30,"t":"عَلَيْهَا تِسْعَةَ عَشَرَ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":31,"t":"وَمَا جَعَلْنَآ أَصْحَٰبَ ٱلنَّارِ إِلَّا مَلَٰٓئِكَةً وَمَا جَعَلْنَا عِدَّتَهُمْ إِلَّا فِتْنَةً لِ͏ّلَّذِينَ كَفَرُوا۟ لِيَسْتَيْقِنَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ وَيَزْدَادَ ٱلَّذِينَ ءَامَنُوٓا۟ إِيمَٰنًا وَلَا يَرْتَابَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ وَٱلْمُؤْمِنُونَ وَلِيَقُولَ ٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌ وَٱلْكَٰفِرُونَ مَاذَآ أَرَادَ ٱللَّهُ بِهَٰذَا مَثَلًا كَذَٰلِكَ يُضِلُّ ٱللَّهُ مَن يَشَآءُ وَيَهْدِى مَن يَشَآءُ وَمَا يَعْلَمُ جُنُودَ رَبِ͏ّكَ إِلَّا هُوَ وَمَا هِىَ إِلَّا ذِكْرَىٰ لِلْبَشَرِ","p":576,"j":29,"h":230,"rk":510,"m":7},{"v":32,"t":"كَلَّا وَٱلْقَمَرِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":33,"t":"وَٱلَّيْلِ إِذْ أَدْبَرَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":34,"t":"وَٱلصُّبْحِ إِذَآ أَسْفَرَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":35,"t":"إِنَّهَا لَإِحْدَى ٱلْكُبَرِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":36,"t":"نَذِيرًا لِ͏ّلْبَشَرِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":37,"t":"لِمَن شَآءَ مِنكُمْ أَن يَتَقَدَّمَ أَوْ يَتَأَخَّرَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":38,"t":"كُلُّ نَفْسٍۭ بِمَا كَسَبَتْ رَهِينَةٌ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":39,"t":"إِلَّآ أَصْحَٰبَ ٱلْيَمِينِ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":40,"t":"فِى جَنَّٰتٍ يَتَسَآءَلُونَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":41,"t":"عَنِ ٱلْمُجْرِمِينَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":42,"t":"مَا سَلَكَكُمْ فِى سَقَرَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":43,"t":"قَالُوا۟ لَمْ نَكُ مِنَ ٱلْمُصَلِ͏ّينَ","p":576,"j":29,"h":230,"rk":511,"m":7},{"v":44,"t":"وَل