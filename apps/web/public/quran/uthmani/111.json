{"verses":[{"v":1,"t":"تَبَّتْ يَدَآ أَبِى لَهَبٍ وَتَبَّ","p":603,"j":30,"h":240,"rk":553,"m":7},{"v":2,"t":"مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ","p":603,"j":30,"h":240,"rk":553,"m":7},{"v":3,"t":"سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ","p":603,"j":30,"h":240,"rk":553,"m":7},{"v":4,"t":"وَٱمْرَأَتُهُۥ حَمَّالَةَ ٱلْحَطَبِ","p":603,"j":30,"h":240,"rk":553,"m":7},{"v":5,"t":"فِى جِيدِهَا حَبْلٌ مِ͏ّن مَّسَدٍۭ","p":603,"j":30,"h":240,"rk":553,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}