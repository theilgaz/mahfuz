{"verses":[{"v":1,"t":"إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا","p":599,"j":30,"h":239,"rk":541,"m":7},{"v":2,"t":"وَأَخْرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا","p":599,"j":30,"h":239,"rk":541,"m":7},{"v":3,"t":"وَقَالَ ٱلْإِنسَٰنُ مَا لَهَا","p":599,"j":30,"h":239,"rk":541,"m":7},{"v":4,"t":"يَوْمَئِذٍ تُحَدِ͏ّثُ أَخْبَارَهَا","p":599,"j":30,"h":239,"rk":541,"m":7},{"v":5,"t":"بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا","p":599,"j":30,"h":239,"rk":541,"m":7},{"v":6,"t":"يَوْمَئِذٍ يَصْدُرُ ٱلنَّاسُ أَشْتَاتًا لِ͏ّيُرَوْا۟ أَعْمَٰلَهُمْ","p":599,"j":30,"h":239,"rk":541,"m":7},{"v":7,"t":"فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُۥ","p":599,"j":30,"h":239,"rk":541,"m":7},{"v":8,"t":"وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُۥ","p":599,"j":30,"h":239,"rk":541,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}