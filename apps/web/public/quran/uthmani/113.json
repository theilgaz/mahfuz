{"verses":[{"v":1,"t":"قُلْ أَعُوذُ بِرَبِ͏ّ ٱلْفَلَقِ","p":604,"j":30,"h":240,"rk":555,"m":7},{"v":2,"t":"مِن شَرِ͏ّ مَا خَلَقَ","p":604,"j":30,"h":240,"rk":555,"m":7},{"v":3,"t":"وَمِن شَرِ͏ّ غَاسِقٍ إِذَا وَقَبَ","p":604,"j":30,"h":240,"rk":555,"m":7},{"v":4,"t":"وَمِن شَرِ͏ّ ٱلنَّفَّٰثَٰتِ فِى ٱلْعُقَدِ","p":604,"j":30,"h":240,"rk":555,"m":7},{"v":5,"t":"وَمِن شَرِ͏ّ حَاسِدٍ إِذَا حَسَدَ","p":604,"j":30,"h":240,"rk":555,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}