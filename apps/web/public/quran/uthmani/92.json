{"verses":[{"v":1,"t":"وَٱلَّيْلِ إِذَا يَغْشَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":2,"t":"وَٱلنَّهَارِ إِذَا تَجَلَّىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":3,"t":"وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":4,"t":"إِنَّ سَعْيَكُمْ لَشَتَّىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":5,"t":"فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":6,"t":"وَصَدَّقَ بِٱلْحُسْنَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":7,"t":"فَسَنُيَسِ͏ّرُهُۥ لِلْيُسْرَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":8,"t":"وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":9,"t":"وَكَذَّبَ بِٱلْحُسْنَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":10,"t":"فَسَنُيَسِ͏ّرُهُۥ لِلْعُسْرَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":11,"t":"وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":12,"t":"إِنَّ عَلَيْنَا لَلْهُدَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":13,"t":"وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":14,"t":"فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ","p":595,"j":30,"h":238,"rk":534,"m":7},{"v":15,"t":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","p":596,"j":30,"h":238,"rk":534,"m":7},{"v":16,"t":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ","p":596,"j":30,"h":238,"rk":534,"m":7},{"v":17,"t":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى","p":596,"j":30,"h":238,"rk":534,"m":7},{"v":18,"t":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ","p":596,"j":30,"h":238,"rk":534,"m":7},{"v":19,"t":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِ͏ّعْمَةٍ تُجْزَىٰٓ","p":596,"j":30,"h":238,"rk":534,"m":7},{"v":20,"t":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِ͏ّهِ ٱلْأَعْلَىٰ","p":596,"j":30,"h":238,"rk":534,"m":7},{"v":21,"t":"وَلَسَوْفَ يَرْضَىٰ","p":596,"j":30,"h":238,"rk":534,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}