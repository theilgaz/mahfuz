{"verses":[{"v":1,"t":"نٓ وَٱلْقَلَمِ وَمَا يَسْطُرُونَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":2,"t":"مَآ أَنتَ بِنِعْمَةِ رَبِ͏ّكَ بِمَجْنُونٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":3,"t":"وَإِنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":4,"t":"وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":5,"t":"فَسَتُبْصِرُ وَيُبْصِرُونَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":6,"t":"بِأَييِ͏ّكُمُ ٱلْمَفْتُونُ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":7,"t":"إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِٱلْمُهْتَدِينَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":8,"t":"فَلَا تُطِعِ ٱلْمُكَذِ͏ّبِينَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":9,"t":"وَدُّوا۟ لَوْ تُدْهِنُ فَيُدْهِنُونَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":10,"t":"وَلَا تُطِعْ كُلَّ حَلَّافٍ مَّهِينٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":11,"t":"هَمَّازٍ مَّشَّآءٍۭ بِنَمِيمٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":12,"t":"مَّنَّاعٍ لِ͏ّلْخَيْرِ مُعْتَدٍ أَثِيمٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":13,"t":"عُتُلٍّۭ بَعْدَ ذَٰلِكَ زَنِيمٍ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":14,"t":"أَن كَانَ ذَا مَالٍ وَبَنِينَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":15,"t":"إِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلْأَوَّلِينَ","p":564,"j":29,"h":226,"rk":498,"m":7},{"v":16,"t":"سَنَسِمُهُۥ عَلَى ٱلْخُرْطُومِ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":17,"t":"إِنَّا بَلَوْنَٰهُمْ كَمَا بَلَوْنَآ أَصْحَٰبَ ٱلْجَنَّةِ إِذْ أَقْسَمُوا۟ لَيَصْرِمُنَّهَا مُصْبِحِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":18,"t":"وَلَا يَسْتَثْنُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":19,"t":"فَطَافَ عَلَيْهَا طَآئِفٌ مِ͏ّن رَّبِ͏ّكَ وَهُمْ نَآئِمُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":20,"t":"فَأَصْبَحَتْ كَٱلصَّرِيمِ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":21,"t":"فَتَنَادَوْا۟ مُصْبِحِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":22,"t":"أَنِ ٱغْدُوا۟ عَلَىٰ حَرْثِكُمْ إِن كُنتُمْ صَٰرِمِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":23,"t":"فَٱنطَلَقُوا۟ وَهُمْ يَتَخَٰفَتُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":24,"t":"أَن لَّا يَدْخُلَنَّهَا ٱلْيَوْمَ عَلَيْكُم مِ͏ّسْكِينٌ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":25,"t":"وَغَدَوْا۟ عَلَىٰ حَرْدٍ قَٰدِرِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":26,"t":"فَلَمَّا رَأَوْهَا قَالُوٓا۟ إِنَّا لَضَآلُّونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":27,"t":"بَلْ نَحْنُ مَحْرُومُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":28,"t":"قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِ͏ّحُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":29,"t":"قَالُوا۟ سُبْحَٰنَ رَبِ͏ّنَآ إِنَّا كُنَّا ظَٰلِمِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":30,"t":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَلَٰوَمُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":31,"t":"قَالُوا۟ يَٰوَيْلَنَآ إِنَّا كُنَّا طَٰغِينَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":32,"t":"عَسَىٰ رَبُّنَآ أَن يُبْدِلَنَا خَيْرًا مِ͏ّنْهَآ إِنَّآ إِلَىٰ رَبِ͏ّنَا رَٰغِبُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":33,"t":"كَذَٰلِكَ ٱلْعَذَابُ وَلَعَذَابُ ٱلْـَٔاخِرَةِ أَكْبَرُ لَوْ كَانُوا۟ يَعْلَمُونَ","p":565,"j":29,"h":226,"rk":498,"m":7},{"v":34,"t":"إِنَّ لِلْمُتَّقِينَ عِندَ رَبِ͏ّهِمْ جَنَّٰتِ ٱلنَّعِيمِ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":35,"t":"أَفَنَجْعَلُ ٱلْمُسْلِمِينَ كَٱلْمُجْرِمِينَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":36,"t":"مَا لَكُمْ كَيْفَ تَحْكُمُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":37,"t":"أَمْ لَكُمْ كِتَٰبٌ فِيهِ تَدْرُسُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":38,"t":"إِنَّ لَكُمْ فِيهِ لَمَا تَخَيَّرُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":39,"t":"أَمْ لَكُمْ أَيْمَٰنٌ عَلَيْنَا بَٰلِغَةٌ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ إِنَّ لَكُمْ لَمَا تَحْكُمُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":40,"t":"سَلْهُمْ أَيُّهُم بِذَٰلِكَ زَعِيمٌ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":41,"t":"أَمْ لَهُمْ شُرَكَآءُ فَلْيَأْتُوا۟ بِشُرَكَآئِهِمْ إِن كَانُوا۟ صَٰدِقِينَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":42,"t":"يَوْمَ يُكْشَفُ عَن سَاقٍ وَيُدْعَوْنَ إِلَى ٱلسُّجُودِ فَلَا يَسْتَطِيعُونَ","p":565,"j":29,"h":226,"rk":499,"m":7},{"v":43,"t":"خَٰشِعَةً أَبْصَٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌ وَقَدْ كَانُوا۟ يُدْعَوْنَ إِلَى ٱلسُّجُودِ وَهُمْ سَٰلِمُونَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":44,"t":"فَذَرْنِى وَمَن يُكَذِ͏ّبُ بِهَٰذَا ٱلْحَدِيثِ سَنَسْتَدْرِجُهُم مِ͏ّنْ حَيْثُ لَا يَعْلَمُونَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":45,"t":"وَأُمْلِى لَهُمْ إِنَّ كَيْدِى مَتِينٌ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":46,"t":"أَمْ تَسْـَٔلُهُمْ أَجْرًا فَهُم مِ͏ّن مَّغْرَمٍ مُّثْقَلُونَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":47,"t":"أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":48,"t":"فَٱصْبِرْ لِحُكْمِ رَبِ͏ّكَ وَلَا تَكُن كَصَاحِبِ ٱلْحُوتِ إِذْ نَادَىٰ وَهُوَ مَكْظُومٌ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":49,"t":"لَّوْلَآ أَن تَدَٰرَكَهُۥ نِعْمَةٌ مِ͏ّن رَّبِ͏ّهِۦ لَنُبِذَ بِٱلْعَرَآءِ وَهُوَ مَذْمُومٌ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":50,"t":"فَٱجْتَبَٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّٰلِحِينَ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":51,"t":"وَإِن يَكَادُ ٱلَّذِينَ كَفَرُوا۟ لَيُزْلِقُونَكَ بِأَبْصَٰرِهِمْ لَمَّا سَمِعُوا۟ ٱلذِ͏ّكْرَ وَيَقُولُونَ إِنَّهُۥ لَمَجْنُونٌ","p":566,"j":29,"h":226,"rk":499,"m":7},{"v":52,"t":"وَمَا هُوَ إِلَّا ذِكْرٌ لِ͏ّلْعَٰلَمِينَ","p":566,"j":29,"h":226,"rk":499,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}