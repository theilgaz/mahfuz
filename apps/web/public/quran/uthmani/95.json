{"verses":[{"v":1,"t":"وَٱلتِ͏ّينِ وَٱلزَّيْتُونِ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":2,"t":"وَطُورِ سِينِينَ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":3,"t":"وَهَٰذَا ٱلْبَلَدِ ٱلْأَمِينِ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":4,"t":"لَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":5,"t":"ثُمَّ رَدَدْنَٰهُ أَسْفَلَ سَٰفِلِينَ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":6,"t":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":7,"t":"فَمَا يُكَذِ͏ّبُكَ بَعْدُ بِٱلدِ͏ّينِ","p":597,"j":30,"h":239,"rk":537,"m":7},{"v":8,"t":"أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَٰكِمِينَ","p":597,"j":30,"h":239,"rk":537,"m":7}],"bismillah":"بِ͏ّسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}