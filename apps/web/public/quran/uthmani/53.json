{"verses":[{"v":1,"t":"وَٱلنَّجْمِ إِذَا هَوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":2,"t":"مَا ضَلَّ صَاحِبُكُمْ وَمَا غَوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":3,"t":"وَمَا يَنطِقُ عَنِ ٱلْهَوَىٰٓ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":4,"t":"إِنْ هُوَ إِلَّا وَحْىٌ يُوحَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":5,"t":"عَلَّمَهُۥ شَدِيدُ ٱلْقُوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":6,"t":"ذُو مِرَّةٍ فَٱسْتَوَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":7,"t":"وَهُوَ بِٱلْأُفُقِ ٱلْأَعْلَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":8,"t":"ثُمَّ دَنَا فَتَدَلَّىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":9,"t":"فَكَانَ قَابَ قَوْسَيْنِ أَوْ أَدْنَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":10,"t":"فَأَوْحَىٰٓ إِلَىٰ عَبْدِهِۦ مَآ أَوْحَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":11,"t":"مَا كَذَبَ ٱلْفُؤَادُ مَا رَأَىٰٓ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":12,"t":"أَفَتُمَٰرُونَهُۥ عَلَىٰ مَا يَرَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":13,"t":"وَلَقَدْ رَءَاهُ نَزْلَةً أُخْرَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":14,"t":"عِندَ سِدْرَةِ ٱلْمُنتَهَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":15,"t":"عِندَهَا جَنَّةُ ٱلْمَأْوَىٰٓ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":16,"t":"إِذْ يَغْشَى ٱلسِ͏ّدْرَةَ مَا يَغْشَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":17,"t":"مَا زَاغَ ٱلْبَصَرُ وَمَا طَغَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":18,"t":"لَقَدْ رَأَىٰ مِنْ ءَايَٰتِ رَبِ͏ّهِ ٱلْكُبْرَىٰٓ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":19,"t":"أَفَرَءَيْتُمُ ٱللَّٰتَ وَٱلْعُزَّىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":20,"t":"وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلْأُخْرَىٰٓ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":21,"t":"أَلَكُمُ ٱلذَّكَرُ وَلَهُ ٱلْأُنثَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":22,"t":"تِلْكَ إِذًا قِسْمَةٌ ضِيزَىٰٓ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":23,"t":"إِنْ هِىَ إِلَّآ أَسْمَآءٌ سَمَّيْتُمُوهَآ أَنتُمْ وَءَابَآؤُكُم مَّآ أَنزَلَ ٱللَّهُ بِهَا مِن سُلْطَٰنٍ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَمَا تَهْوَى ٱلْأَنفُسُ وَلَقَدْ جَآءَهُم مِ͏ّن رَّبِ͏ّهِمُ ٱلْهُدَىٰٓ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":24,"t":"أَمْ لِلْإِنسَٰنِ مَا تَمَنَّىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":25,"t":"فَلِلَّهِ ٱلْـَٔاخِرَةُ وَٱلْأُولَىٰ","p":526,"j":27,"h":210,"rk":460,"m":7},{"v":26,"t":"وَكَم مِ͏ّن مَّلَكٍ فِى ٱلسَّمَٰوَٰتِ لَا تُغْنِى شَفَٰعَتُهُمْ شَيْـًٔا إِلَّا مِنۢ بَعْدِ أَن يَأْذَنَ ٱللَّهُ لِمَن يَشَآءُ وَيَرْضَىٰٓ","p":526,"j":27,"h":211,"rk":461,"m":7},{"v":27,"t":"إِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْـَٔاخِرَةِ لَيُسَمُّونَ ٱلْمَلَٰٓئِكَةَ تَسْمِيَةَ ٱلْأُنثَىٰ","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":28,"t":"وَمَا لَهُم بِهِۦ مِنْ عِلْمٍ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَإِنَّ ٱلظَّنَّ لَا يُغْنِى مِنَ ٱلْحَقِ͏ّ شَيْـًٔا","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":29,"t":"فَأَعْرِضْ عَن مَّن تَوَلَّىٰ عَن ذِكْرِنَا وَلَمْ يُرِدْ إِلَّا ٱلْحَيَوٰةَ ٱلدُّنْيَا","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":30,"t":"ذَٰلِكَ مَبْلَغُهُم مِ͏ّنَ ٱلْعِلْمِ إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِمَنِ ٱهْتَدَىٰ","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":31,"t":"وَلِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ لِيَجْزِىَ ٱلَّذِينَ أَسَٰٓـُٔوا۟ بِمَا عَمِلُوا۟ وَيَجْزِىَ ٱلَّذِينَ أَحْسَنُوا۟ بِٱلْحُسْنَى","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":32,"t":"ٱلَّذِينَ يَجْتَنِبُونَ كَبَٰٓئِرَ ٱلْإِثْمِ وَٱلْفَوَٰحِشَ إِلَّا ٱللَّمَمَ إِنَّ رَبَّكَ وَٰسِعُ ٱلْمَغْفِرَةِ هُوَ أَعْلَمُ بِكُمْ إِذْ أَنشَأَكُم مِ͏ّنَ ٱلْأَرْضِ وَإِذْ أَنتُمْ أَجِنَّةٌ فِى بُطُونِ أُمَّهَٰتِكُمْ فَلَا تُزَكُّوٓا۟ أَنفُسَكُمْ هُوَ أَعْلَمُ بِمَنِ ٱتَّقَىٰٓ","p":527,"j":27,"h":211,"rk":461,"m":7},{"v":33,"t":"أَفَرَءَيْتَ ٱلَّذِى تَوَلَّىٰ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":34,"t":"وَأَعْطَىٰ قَلِيلًا وَأَكْدَىٰٓ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":35,"t":"أَعِندَهُۥ عِلْمُ ٱلْغَيْبِ فَهُوَ يَرَىٰٓ","p":527,"j":27,"h":211,"rk":462,"m":7},{"v":36,"t":"أَم