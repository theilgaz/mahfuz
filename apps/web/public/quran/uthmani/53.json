"لَيْسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":59,"t":"أَفَمِنْ هَٰذَا ٱلْحَدِيثِ تَعْجَبُونَ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":60,"t":"وَتَضْحَكُونَ وَلَا تَبْكُونَ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":61,"t":"وَأَنتُمْ سَٰمِدُونَ","p":528,"j":27,"h":211,"rk":462,"m":7},{"v":62,"t":"فَٱسْجُدُوا۟ لِلَّهِ وَٱعْبُدُوا۟","p":528,"j":27,"h":211,"rk":462,"m":7,"sj":2}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}