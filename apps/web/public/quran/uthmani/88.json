{"verses":[{"v":1,"t":"هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":2,"t":"وُجُوهٌ يَوْمَئِذٍ خَٰشِعَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":3,"t":"عَامِلَةٌ نَّاصِبَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":4,"t":"تَصْلَىٰ نَارًا حَامِيَةً","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":5,"t":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":6,"t":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":7,"t":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":8,"t":"وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":9,"t":"لِ͏ّسَعْيِهَا رَاضِيَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":10,"t":"فِى جَنَّةٍ عَالِيَةٍ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":11,"t":"لَّا تَسْمَعُ فِيهَا لَٰغِيَةً","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":12,"t":"فِيهَا عَيْنٌ جَارِيَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":13,"t":"فِيهَا سُرُرٌ مَّرْفُوعَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":14,"t":"وَأَكْوَابٌ مَّوْضُوعَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":15,"t":"وَنَمَارِقُ مَصْفُوفَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":16,"t":"وَزَرَابِىُّ مَبْثُوثَةٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":17,"t":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":18,"t":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":19,"t":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":20,"t":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":21,"t":"فَذَكِ͏ّرْ إِنَّمَآ أَنتَ مُذَكِ͏ّرٌ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":22,"t":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":23,"t":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":24,"t":"فَيُعَذِ͏ّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":25,"t":"إِنَّ إِلَيْنَآ إِيَابَهُمْ","p":592,"j":30,"h":237,"rk":530,"m":7},{"v":26,"t":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم","p":592,"j":30,"h":237,"rk":530,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}