{"verses":[{"v":1,"t":"سَأَلَ سَآئِلٌۢ بِعَذَابٍ وَاقِعٍ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":2,"t":"لِ͏ّلْكَٰفِرِينَ لَيْسَ لَهُۥ دَافِعٌ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":3,"t":"مِ͏ّنَ ٱللَّهِ ذِى ٱلْمَعَارِجِ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":4,"t":"تَعْرُجُ ٱلْمَلَٰٓئِكَةُ وَٱلرُّوحُ إِلَيْهِ فِى يَوْمٍ كَانَ مِقْدَارُهُۥ خَمْسِينَ أَلْفَ سَنَةٍ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":5,"t":"فَٱصْبِرْ صَبْرًا جَمِيلًا","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":6,"t":"إِنَّهُمْ يَرَوْنَهُۥ بَعِيدًا","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":7,"t":"وَنَرَىٰهُ قَرِيبًا","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":8,"t":"يَوْمَ تَكُونُ ٱلسَّمَآءُ كَٱلْمُهْلِ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":9,"t":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":10,"t":"وَلَا يَسْـَٔلُ حَمِيمٌ حَمِيمًا","p":568,"j":29,"h":227,"rk":502,"m":7},{"v":11,"t":"يُبَصَّرُونَهُمْ يَوَدُّ ٱلْمُجْرِمُ لَوْ يَفْتَدِى مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيهِ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":12,"t":"وَصَٰحِبَتِهِۦ وَأَخِيهِ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":13,"t":"وَفَصِيلَتِهِ ٱلَّتِى تُـْٔوِيهِ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":14,"t":"وَمَن فِى ٱلْأَرْضِ جَمِيعًا ثُمَّ يُنجِيهِ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":15,"t":"كَلَّآ إِنَّهَا لَظَىٰ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":16,"t":"نَزَّاعَةً لِ͏ّلشَّوَىٰ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":17,"t":"تَدْعُوا۟ مَنْ أَدْبَرَ وَتَوَلَّىٰ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":18,"t":"وَجَمَعَ فَأَوْعَىٰٓ","p":569,"j":29,"h":227,"rk":502,"m":7},{"v":19,"t":"إِنَّ ٱلْإِنسَٰنَ خُلِقَ هَلُوعًا","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":20,"t":"إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعًا","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":21,"t":"وَإِذَا مَسَّهُ ٱلْخَيْرُ مَنُوعًا","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":22,"t":"إِلَّا ٱلْمُصَلِ͏ّينَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":23,"t":"ٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَآئِمُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":24,"t":"وَٱلَّذِينَ فِىٓ أَمْوَٰلِهِمْ حَقٌّ مَّعْلُومٌ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":25,"t":"لِ͏ّلسَّآئِلِ وَٱلْمَحْرُومِ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":26,"t":"وَٱلَّذِينَ يُصَدِ͏ّقُونَ بِيَوْمِ ٱلدِ͏ّينِ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":27,"t":"وَٱلَّذِينَ هُم مِ͏ّنْ عَذَابِ رَبِ͏ّهِم مُّشْفِقُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":28,"t":"إِنَّ عَذَابَ رَبِ͏ّهِمْ غَيْرُ مَأْمُونٍ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":29,"t":"وَٱلَّذِينَ هُمْ لِفُرُوجِهِمْ حَٰفِظُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":30,"t":"إِلَّا عَلَىٰٓ أَزْوَٰجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":31,"t":"فَمَنِ ٱبْتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُو۟لَٰٓئِكَ هُمُ ٱلْعَادُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":32,"t":"وَٱلَّذِينَ هُمْ لِأَمَٰنَٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":33,"t":"وَٱلَّذِينَ هُم بِشَهَٰدَٰتِهِمْ قَآئِمُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":34,"t":"وَٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":35,"t":"أُو۟لَٰٓئِكَ فِى جَنَّٰتٍ مُّكْرَمُونَ","p":569,"j":29,"h":228,"rk":502,"m":7},{"v":36,"t":"فَمَالِ ٱلَّذِينَ كَفَرُوا۟ قِبَلَكَ مُهْطِعِينَ","p":569,"j":29,"h":228,"rk":503,"m":7},{"v":37,"t":"عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِ͏ّمَالِ عِزِينَ","p":569,"j":29,"h":228,"rk":503,"m":7},{"v":38,"t":"أَيَطْمَعُ كُلُّ ٱمْرِئٍ مِ͏ّنْهُمْ أَن يُدْخَلَ جَنَّةَ نَعِيمٍ","p":569,"j":29,"h":228,"rk":503,"m":7},{"v":39,"t":"كَلَّآ إِنَّا خَلَقْنَٰهُم مِ͏ّمَّا يَعْلَمُونَ","p":569,"j":29,"h":228,"rk":503,"m":7},{"v":40,"t":"فَلَآ أُقْسِمُ بِرَبِ͏ّ ٱلْمَشَٰرِقِ وَٱلْمَغَٰرِبِ إِنَّا لَقَٰدِرُونَ","p":570,"j":29,"h":228,"rk":503,"m":7},{"v":41,"t":"عَلَىٰٓ أَن نُّبَدِ͏ّلَ خَيْرًا مِ͏ّنْهُمْ وَمَا نَحْنُ بِمَسْبُوقِينَ","p":570,"j":29,"h":228,"rk":503,"m":7},{"v":42,"t":"فَذَرْهُمْ يَخُوضُوا۟ وَيَلْعَبُوا۟ حَتَّىٰ يُلَٰقُوا۟ يَوْمَهُمُ ٱلَّذِى يُوعَدُونَ","p":570,"j":29,"h":228,"rk":503,"m":7},{"v":43,"t":"يَوْمَ يَخْرُجُونَ مِنَ ٱلْأَجْدَاثِ سِرَاعًا كَأَنَّهُمْ إِلَىٰ نُصُبٍ يُوفِضُونَ","p":570,"j":29,"h":228,"rk":503,"m":7},{"v":44,"t":"خَٰشِعَةً أَبْصَٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌ ذَٰلِكَ ٱلْيَوْمُ ٱلَّذِى كَانُوا۟ يُوعَدُونَ","p":570,"j":29,"h":228,"rk":503,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}