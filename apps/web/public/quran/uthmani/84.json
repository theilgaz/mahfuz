{"verses":[{"v":1,"t":"إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":2,"t":"وَأَذِنَتْ لِرَبِ͏ّهَا وَحُقَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":3,"t":"وَإِذَا ٱلْأَرْضُ مُدَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":4,"t":"وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":5,"t":"وَأَذِنَتْ لِرَبِ͏ّهَا وَحُقَّتْ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":6,"t":"يَٰٓأَيُّهَا ٱلْإِنسَٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِ͏ّكَ كَدْحًا فَمُلَٰقِيهِ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":7,"t":"فَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ بِيَمِينِهِۦ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":8,"t":"فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":9,"t":"وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":10,"t":"وَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ وَرَآءَ ظَهْرِهِۦ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":11,"t":"فَسَوْفَ يَدْعُوا۟ ثُبُورًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":12,"t":"وَيَصْلَىٰ سَعِيرًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":13,"t":"إِنَّهُۥ كَانَ فِىٓ أَهْلِهِۦ مَسْرُورًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":14,"t":"إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":15,"t":"بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًا","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":16,"t":"فَلَآ أُقْسِمُ بِٱلشَّفَقِ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":17,"t":"وَٱلَّيْلِ وَمَا وَسَقَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":18,"t":"وَٱلْقَمَرِ إِذَا ٱتَّسَقَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":19,"t":"لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":20,"t":"فَمَا لَهُمْ لَا يُؤْمِنُونَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":21,"t":"وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ","p":589,"j":30,"h":236,"rk":526,"m":7,"sj":1},{"v":22,"t":"بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِ͏ّبُونَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":23,"t":"وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":24,"t":"فَبَشِ͏ّرْهُم بِعَذَابٍ أَلِيمٍ","p":589,"j":30,"h":236,"rk":526,"m":7},{"v":25,"t":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۭ","p":589,"j":30,"h":236,"rk":526,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}