{"verses":[{"v":1,"t":"وَٱلنَّٰزِعَٰتِ غَرْقًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":2,"t":"وَٱلنَّٰشِطَٰتِ نَشْطًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":3,"t":"وَٱلسَّٰبِحَٰتِ سَبْحًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":4,"t":"فَٱلسَّٰبِقَٰتِ سَبْقًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":5,"t":"فَٱلْمُدَبِ͏ّرَٰتِ أَمْرًا","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":6,"t":"يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":7,"t":"تَتْبَعُهَا ٱلرَّادِفَةُ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":8,"t":"قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":9,"t":"أَبْصَٰرُهَا خَٰشِعَةٌ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":10,"t":"يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":11,"t":"أَءِذَا كُنَّا عِظَٰمًا نَّخِرَةً","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":12,"t":"قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":13,"t":"فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":14,"t":"فَإِذَا هُم بِٱلسَّاهِرَةِ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":15,"t":"هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ","p":583,"j":30,"h":233,"rk":520,"m":7},{"v":16,"t":"إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":17,"t":"ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":18,"t":"فَقُلْ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":19,"t":"وَأَهْدِيَكَ إِلَىٰ رَبِ͏ّكَ فَتَخْشَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":20,"t":"فَأَرَىٰهُ ٱلْـَٔايَةَ ٱلْكُبْرَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":21,"t":"فَكَذَّبَ وَعَصَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":22,"t":"ثُمَّ أَدْبَرَ يَسْعَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":23,"t":"فَحَشَرَ فَنَادَىٰ","p":584,"j":30,"h":233,"rk":520,"m":7},{"v":24,"t":"فَقَالَ أَنَا۠ رَبُّكُمُ ٱلْأَعْلَىٰ","p":584,