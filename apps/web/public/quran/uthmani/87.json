{"verses":[{"v":1,"t":"سَبِ͏ّحِ ٱسْمَ رَبِ͏ّكَ ٱلْأَعْلَى","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":2,"t":"ٱلَّذِى خَلَقَ فَسَوَّىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":3,"t":"وَٱلَّذِى قَدَّرَ فَهَدَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":4,"t":"وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":5,"t":"فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":6,"t":"سَنُقْرِئُكَ فَلَا تَنسَىٰٓ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":7,"t":"إِلَّا مَا شَآءَ ٱللَّهُ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":8,"t":"وَنُيَسِ͏ّرُكَ لِلْيُسْرَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":9,"t":"فَذَكِ͏ّرْ إِن نَّفَعَتِ ٱلذِ͏ّكْرَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":10,"t":"سَيَذَّكَّرُ مَن يَخْشَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":11,"t":"وَيَتَجَنَّبُهَا ٱلْأَشْقَى","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":12,"t":"ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":13,"t":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":14,"t":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":15,"t":"وَذَكَرَ ٱسْمَ رَبِ͏ّهِۦ فَصَلَّىٰ","p":591,"j":30,"h":237,"rk":529,"m":7},{"v":16,"t":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","p":592,"j":30,"h":237,"rk":529,"m":7},{"v":17,"t":"وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ","p":592,"j":30,"h":237,"rk":529,"m":7},{"v":18,"t":"إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","p":592,"j":30,"h":237,"rk":529,"m":7},{"v":19,"t":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","p":592,"j":30,"h":237,"rk":529,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}