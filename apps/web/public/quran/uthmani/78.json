{"verses":[{"v":1,"t":"عَمَّ يَتَسَآءَلُونَ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":2,"t":"عَنِ ٱلنَّبَإِ ٱلْعَظِيمِ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":3,"t":"ٱلَّذِى هُمْ فِيهِ مُخْتَلِفُونَ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":4,"t":"كَلَّا سَيَعْلَمُونَ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":5,"t":"ثُمَّ كَلَّا سَيَعْلَمُونَ","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":6,"t":"أَلَمْ نَجْعَلِ ٱلْأَرْضَ مِهَٰدًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":7,"t":"وَٱلْجِبَالَ أَوْتَادًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":8,"t":"وَخَلَقْنَٰكُمْ أَزْوَٰجًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":9,"t":"وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":10,"t":"وَجَعَلْنَا ٱلَّيْلَ لِبَاسًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":11,"t":"وَجَعَلْنَا ٱلنَّهَارَ مَعَاشًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":12,"t":"وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":13,"t":"وَجَعَلْنَا سِرَاجًا وَهَّاجًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":14,"t":"وَأَنزَلْنَا مِنَ ٱلْمُعْصِرَٰتِ مَآءً ثَجَّاجًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":15,"t":"لِ͏ّنُخْرِجَ بِهِۦ حَبًّا وَنَبَاتًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":16,"t":"وَجَنَّٰتٍ أَلْفَافًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":17,"t":"إِنَّ يَوْمَ ٱلْفَصْلِ كَانَ مِيقَٰتًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":18,"t":"يَوْمَ يُنفَخُ فِى ٱلصُّورِ فَتَأْتُونَ أَفْوَاجًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":19,"t":"وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتْ أَبْوَٰبًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":20,"t":"وَسُيِ͏ّرَتِ ٱلْجِبَالُ فَكَانَتْ سَرَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":21,"t":"إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":22,"t":"لِ͏ّلطَّٰغِينَ مَـَٔابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":23,"t":"لَّٰبِثِينَ فِيهَآ أَحْقَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":24,"t":"لَّا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":25,"t":"إِلَّا حَمِيمًا وَغَسَّاقًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":26,"t":"جَزَآءً وِفَاقًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":27,"t":"إِنَّهُمْ كَانُوا۟ لَا يَرْجُونَ حِسَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":28,"t":"وَكَذَّبُوا۟ بِـَٔايَٰتِنَا كِذَّابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":29,"t":"وَكُلَّ شَىْءٍ أَحْصَيْنَٰهُ كِتَٰبًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":30,"t":"فَذُوقُوا۟ فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا","p":582,"j":30,"h":233,"rk":518,"m":7},{"v":31,"t":"إِنَّ لِلْمُتَّقِينَ مَفَازًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":32,"t":"حَدَآئِقَ وَأَعْنَٰبًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":33,"t":"وَكَوَاعِبَ أَتْرَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":34,"t":"وَكَأْسًا دِهَاقًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":35,"t":"لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّٰبًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":36,"t":"جَزَآءً مِ͏ّن رَّبِ͏ّكَ عَطَآءً حِسَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":37,"t":"رَّبِ͏ّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلرَّحْمَٰنِ لَا يَمْلِكُونَ مِنْهُ خِطَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":38,"t":"يَوْمَ يَقُومُ ٱلرُّوحُ وَٱلْمَلَٰٓئِكَةُ صَفًّا لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَٰنُ وَقَالَ صَوَابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":39,"t":"ذَٰلِكَ ٱلْيَوْمُ ٱلْحَقُّ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِ͏ّهِۦ مَـَٔابًا","p":583,"j":30,"h":233,"rk":519,"m":7},{"v":40,"t":"إِنَّآ أَنذَرْنَٰكُمْ عَذَابًا قَرِيبًا يَوْمَ يَنظُرُ ٱلْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ ٱلْكَافِرُ يَٰلَيْتَنِى كُنتُ تُرَٰبًۢا","p":583,"j":30,"h":233,"rk":519,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}