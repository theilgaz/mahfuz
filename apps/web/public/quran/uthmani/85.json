{"verses":[{"v":1,"t":"وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":2,"t":"وَٱلْيَوْمِ ٱلْمَوْعُودِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":3,"t":"وَشَاهِدٍ وَمَشْهُودٍ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":4,"t":"قُتِلَ أَصْحَٰبُ ٱلْأُخْدُودِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":5,"t":"ٱلنَّارِ ذَاتِ ٱلْوَقُودِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":6,"t":"إِذْ هُمْ عَلَيْهَا قُعُودٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":7,"t":"وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":8,"t":"وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":9,"t":"ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَٱللَّهُ عَلَىٰ كُلِ͏ّ شَىْءٍ شَهِيدٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":10,"t":"إِنَّ ٱلَّذِينَ فَتَنُوا۟ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ ثُمَّ لَمْ يَتُوبُوا۟ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ ٱلْحَرِيقِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":11,"t":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ جَنَّٰتٌ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":12,"t":"إِنَّ بَطْشَ رَبِ͏ّكَ لَشَدِيدٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":13,"t":"إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":14,"t":"وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":15,"t":"ذُو ٱلْعَرْشِ ٱلْمَجِيدُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":16,"t":"فَعَّالٌ لِ͏ّمَا يُرِيدُ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":17,"t":"هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":18,"t":"فِرْعَوْنَ وَثَمُودَ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":19,"t":"بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":20,"t":"وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":21,"t":"بَلْ هُوَ قُرْءَانٌ مَّجِيدٌ","p":590,"j":30,"h":236,"rk":527,"m":7},{"v":22,"t":"فِى لَوْحٍ مَّحْفُوظٍۭ","p":590,"j":30,"h":236,"rk":527,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}