{"verses":[{"v":1,"t":"لَآ أُقْسِمُ بِهَٰذَا ٱلْبَلَدِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":2,"t":"وَأَنتَ حِلٌّۢ بِهَٰذَا ٱلْبَلَدِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":3,"t":"وَوَالِدٍ وَمَا وَلَدَ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":4,"t":"لَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ فِى كَبَدٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":5,"t":"أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":6,"t":"يَقُولُ أَهْلَكْتُ مَالًا لُّبَدًا","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":7,"t":"أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":8,"t":"أَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":9,"t":"وَلِسَانًا وَشَفَتَيْنِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":10,"t":"وَهَدَيْنَٰهُ ٱلنَّجْدَيْنِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":11,"t":"فَلَا ٱقْتَحَمَ ٱلْعَقَبَةَ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":12,"t":"وَمَآ أَدْرَىٰكَ مَا ٱلْعَقَبَةُ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":13,"t":"فَكُّ رَقَبَةٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":14,"t":"أَوْ إِطْعَٰمٌ فِى يَوْمٍ ذِى مَسْغَبَةٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":15,"t":"يَتِيمًا ذَا مَقْرَبَةٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":16,"t":"أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":17,"t":"ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُوا۟ وَتَوَاصَوْا۟ بِٱلصَّبْرِ وَتَوَاصَوْا۟ بِٱلْمَرْحَمَةِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":18,"t":"أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْمَيْمَنَةِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":19,"t":"وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَٰتِنَا هُمْ أَصْحَٰبُ ٱلْمَشْـَٔمَةِ","p":594,"j":30,"h":238,"rk":532,"m":7},{"v":20,"t":"عَلَيْهِمْ نَارٌ مُّؤْصَدَةٌۢ","p":594,"j":30,"h":238,"rk":532,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}