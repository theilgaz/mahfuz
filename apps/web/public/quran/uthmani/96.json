{"verses":[{"v":1,"t":"ٱقْرَأْ بِٱسْمِ رَبِ͏ّكَ ٱلَّذِى خَلَقَ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":2,"t":"خَلَقَ ٱلْإِنسَٰنَ مِنْ عَلَقٍ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":3,"t":"ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":4,"t":"ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":5,"t":"عَلَّمَ ٱلْإِنسَٰنَ مَا لَمْ يَعْلَمْ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":6,"t":"كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":7,"t":"أَن رَّءَاهُ ٱسْتَغْنَىٰٓ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":8,"t":"إِنَّ إِلَىٰ رَبِ͏ّكَ ٱلرُّجْعَىٰٓ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":9,"t":"أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":10,"t":"عَبْدًا إِذَا صَلَّىٰٓ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":11,"t":"أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":12,"t":"أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":13,"t":"أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":14,"t":"أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":15,"t":"كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":16,"t":"نَاصِيَةٍ كَٰذِبَةٍ خَاطِئَةٍ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":17,"t":"فَلْيَدْعُ نَادِيَهُۥ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":18,"t":"سَنَدْعُ ٱلزَّبَانِيَةَ","p":597,"j":30,"h":239,"rk":538,"m":7},{"v":19,"t":"كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب","p":597,"j":30,"h":239,"rk":538,"m":7,"sj":2}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}