{"verses":[{"v":1,"t":"وَٱلسَّمَآءِ وَٱلطَّارِقِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":2,"t":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":3,"t":"ٱلنَّجْمُ ٱلثَّاقِبُ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":4,"t":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":5,"t":"فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":6,"t":"خُلِقَ مِن مَّآءٍ دَافِقٍ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":7,"t":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":8,"t":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":9,"t":"يَوْمَ تُبْلَى ٱلسَّرَآئِرُ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":10,"t":"فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":11,"t":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":12,"t":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":13,"t":"إِنَّهُۥ لَقَوْلٌ فَصْلٌ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":14,"t":"وَمَا هُوَ بِٱلْهَزْلِ","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":15,"t":"إِنَّهُمْ يَكِيدُونَ كَيْدًا","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":16,"t":"وَأَكِيدُ كَيْدًا","p":591,"j":30,"h":236,"rk":528,"m":7},{"v":17,"t":"فَمَهِ͏ّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا","p":591,"j":30,"h":236,"rk":528,"m":7}],"bismillah":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ"}