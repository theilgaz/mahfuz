{"verses":[{"v":1,"t":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":2,"t":"ٱلْحَمْدُ لِلَّهِ رَبِ͏ّ ٱلْعَٰلَمِينَ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":3,"t":"ٱلرَّحْمَٰنِ ٱلرَّحِيمِ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":4,"t":"مَٰلِكِ يَوْمِ ٱلدِ͏ّينِ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":5,"t":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":6,"t":"ٱهْدِنَا ٱلصِ͏ّرَٰطَ ٱلْمُسْتَقِيمَ","p":1,"j":1,"h":1,"rk":1,"m":1},{"v":7,"t":"صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوبِ عَلَيْهِمْ وَلَا ٱلضَّآلِ͏ّينَ","p":1,"j":1,"h":1,"rk":1,"m":1}]}